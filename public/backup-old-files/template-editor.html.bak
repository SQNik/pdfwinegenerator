<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HTML Template Editor - Wine Management System</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <!-- CodeMirror CSS for code editor -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/codemirror.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/theme/monokai.min.css">
    
    <!-- Custom styles -->
    <link rel="stylesheet" href="css/style.css">
    
    <style>
        .template-editor-container {
            height: 100vh;
            display: flex;
            flex-direction: column;
        }
        
        .editor-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 1rem;
            flex-shrink: 0;
        }
        
        .editor-body {
            flex: 1;
            overflow: hidden;
        }
        
        .editor-sidebar {
            background: #f8f9fa;
            border-right: 1px solid #dee2e6;
            height: 100%;
            overflow-y: auto;
        }
        
        .editor-main {
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        
        .editor-tabs {
            background: white;
            border-bottom: 1px solid #dee2e6;
            flex-shrink: 0;
        }
        
        .editor-content {
            flex: 1;
            overflow: hidden;
        }
        
        .code-editor {
            height: 100%;
            border: none;
        }
        
        .preview-panel {
            background: white;
            border-left: 1px solid #dee2e6;
            height: 100%;
            overflow: hidden;
        }
        
        .preview-iframe {
            width: 100%;
            height: 100%;
            border: none;
            background: white;
        }
        
        .template-card {
            cursor: pointer;
            transition: all 0.2s ease;
            border: 1px solid #dee2e6;
        }
        
        .template-card:hover {
            border-color: #0d6efd;
            box-shadow: 0 2px 8px rgba(13, 110, 253, 0.15);
        }
        
        .template-card.active {
            border-color: #0d6efd;
            background-color: #e7f1ff;
        }
        
        .template-thumbnail {
            height: 120px;
            background: #f8f9fa;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6c757d;
            font-size: 2rem;
        }
        
        .field-item {
            padding: 8px 12px;
            margin: 4px 0;
            background: #e9ecef;
            border-radius: 4px;
            cursor: grab;
            user-select: none;
            transition: all 0.2s ease;
        }
        
        .field-item:hover {
            background: #0d6efd;
            color: white;
        }
        
        .field-item:active {
            cursor: grabbing;
        }
        
        .status-badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.5rem;
        }
        
        .toolbar {
            background: white;
            border-bottom: 1px solid #dee2e6;
            padding: 0.5rem 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex-shrink: 0;
        }
        
        .editor-tabs .nav-link {
            border: none;
            border-bottom: 2px solid transparent;
            color: #6c757d;
        }
        
        .editor-tabs .nav-link.active {
            border-bottom-color: #0d6efd;
            color: #0d6efd;
        }
        
        .loading-spinner {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 200px;
        }
        
        .empty-state {
            text-align: center;
            padding: 3rem;
            color: #6c757d;
        }
        
        .CodeMirror {
            height: 100% !important;
            font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
            font-size: 14px;
        }
        
        /* Collection Fields Styles */
        .collection-fields-list {
            display: flex; 
            flex-direction: column;
            gap: 0.5rem;
        }
        
        .collection-field-item {
            padding: 0.5rem;
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            cursor: grab;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .collection-field-item:hover {
            background: #e9ecef;
            border-color: #adb5bd;
            transform: translateY(-1px);
        }
        
        .collection-field-item:active {
            cursor: grabbing;
        }
        
        .collection-field-icon {
            color: #6c757d;
            font-size: 0.875rem;
        }
        
        .collection-field-group {
            font-size: 0.75rem;
            color: #6c757d;
            background: #dee2e6;
            padding: 0.125rem 0.375rem;
            border-radius: 0.25rem;
            margin-left: auto;
        }
        
        .collection-field-group.basic {
            background: #d1ecf1;
            color: #0c5460;
        }
        
        .collection-field-group.dynamic {
            background: #d4edda;
            color: #155724;
        }
        
        .collection-field-group.wines {
            background: #fff3cd;
            color: #856404;
        }
        
        .custom-formats-list {
            max-height: 300px;
            overflow-y: auto;
        }
        
        .custom-format-item {
            padding: 8px 12px;
            margin: 4px 0;
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 4px;
            transition: all 0.2s ease;
        }
        
        .custom-format-item:hover {
            background: #e9ecef;
            border-color: #0d6efd;
        }
        
        .custom-format-item.inactive {
            opacity: 0.6;
            background: #f1f3f4;
        }
        
        .custom-format-name {
            font-weight: 500;
            color: #212529;
        }
        
        .custom-format-details {
            font-size: 0.75rem;
            color: #6c757d;
            margin-top: 2px;
        }
        
        .custom-format-actions {
            margin-top: 8px;
        }
        
        .custom-format-actions .btn {
            padding: 2px 8px;
            font-size: 0.75rem;
        }
    </style>
</head>
<body>
    <div class="template-editor-container">
        <!-- Header -->
        <div class="editor-header">
            <div class="container-fluid">
                <div class="row align-items-center">
                    <div class="col">
                        <h1 class="h4 mb-0">
                            <i class="bi bi-code-square me-2"></i>
                            HTML Template Editor
                        </h1>
                        <small class="opacity-75">Twórz profesjonalne szablony HTML dla systemów PDF</small>
                    </div>
                    <div class="col-auto">
                        <div class="btn-group" role="group">
                            <button type="button" class="btn btn-light btn-sm" id="newTemplateBtn">
                                <i class="bi bi-plus-lg me-1"></i>Nowy szablon
                            </button>
                            <button type="button" class="btn btn-light btn-sm" id="saveTemplateBtn" disabled>
                                <i class="bi bi-save me-1"></i>Zapisz
                            </button>
                            <button type="button" class="btn btn-light btn-sm" id="previewBtn" disabled>
                                <i class="bi bi-eye me-1"></i>Podgląd PDF
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Editor Body -->
        <div class="editor-body">
            <div class="row g-0 h-100">
                <!-- Sidebar -->
                <div class="col-3 editor-sidebar">
                    <!-- Templates List -->
                    <div class="p-3">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0">Szablony</h6>
                            <button class="btn btn-sm btn-outline-primary" id="refreshTemplatesBtn">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                        </div>
                        
                        <!-- Categories Filter -->
                        <select class="form-select form-select-sm mb-3" id="categoryFilter">
                            <option value="">Wszystkie kategorie</option>
                        </select>
                        
                        <!-- Search -->
                        <div class="input-group input-group-sm mb-3">
                            <input type="text" class="form-control" id="templateSearch" placeholder="Szukaj szablonów...">
                            <button class="btn btn-outline-secondary" type="button" id="clearSearchBtn">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                        
                        <!-- Templates List -->
                        <div id="templatesList" class="templates-list">
                            <div class="loading-spinner">
                                <div class="spinner-border spinner-border-sm text-primary" role="status">
                                    <span class="visually-hidden">Ładowanie...</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Data Binding Panel -->
                    <div class="p-3 border-top">
                        <h6 class="mb-3">Pola danych</h6>
                        <div class="accordion accordion-flush" id="dataBindingAccordion">
                            <div class="accordion-item">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#wineFieldsCollapse">
                                        <i class="bi bi-tags me-2"></i>Pola wina
                                    </button>
                                </h2>
                                <div id="wineFieldsCollapse" class="accordion-collapse collapse show" data-bs-parent="#dataBindingAccordion">
                                    <div class="accordion-body p-2">
                                        <div id="wineFieldsList" class="wine-fields-list">
                                            <div class="loading-spinner">
                                                <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="accordion-item">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collectionFieldsCollapse">
                                        <i class="bi bi-collection me-2"></i>Pola kolekcji
                                    </button>
                                </h2>
                                <div id="collectionFieldsCollapse" class="accordion-collapse collapse" data-bs-parent="#dataBindingAccordion">
                                    <div class="accordion-body p-2">
                                        <div id="collectionFieldsList" class="collection-fields-list">
                                            <div class="loading-spinner">
                                                <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-3">
                            <small class="text-muted">
                                <i class="bi bi-info-circle me-1"></i>
                                Przeciągnij pola do edytora aby dodać placeholdery
                            </small>
                        </div>
                    </div>

                    <!-- Custom PDF Formats Panel -->
                    <div class="p-3 border-top">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0">
                                <i class="bi bi-file-earmark-pdf me-2"></i>
                                Niestandardowe formaty PDF
                            </h6>
                            <button class="btn btn-sm btn-outline-success" id="addCustomFormatBtn" title="Dodaj nowy format">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                        
                        <div id="customFormatsList" class="custom-formats-list">
                            <div class="loading-spinner text-center">
                                <div class="spinner-border spinner-border-sm text-secondary" role="status">
                                    <span class="visually-hidden">Ładowanie formatów...</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-3">
                            <small class="text-muted">
                                <i class="bi bi-info-circle me-1"></i>
                                Zarządzaj niestandardowymi formatami PDF
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Main Editor Area -->
                <div class="col-6 editor-main">
                    <!-- Toolbar -->
                    <div class="toolbar">
                        <button class="btn btn-sm btn-outline-secondary" id="undoBtn" title="Cofnij">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" id="redoBtn" title="Ponów">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                        
                        <div class="vr"></div>
                        
                        <button class="btn btn-sm btn-outline-secondary" id="formatCodeBtn" title="Formatuj kod">
                            <i class="bi bi-code"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" id="fullScreenBtn" title="Pełny ekran">
                            <i class="bi bi-arrows-fullscreen"></i>
                        </button>
                        
                        <div class="ms-auto">
                            <span class="badge bg-secondary" id="editorStatus">Gotowy</span>
                        </div>
                    </div>

                    <!-- Editor Tabs -->
                    <div class="editor-tabs">
                        <ul class="nav nav-tabs nav-fill" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="html-tab" data-bs-toggle="tab" data-bs-target="#html-editor" type="button">
                                    <i class="bi bi-filetype-html me-1"></i>HTML
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="css-tab" data-bs-toggle="tab" data-bs-target="#css-editor" type="button">
                                    <i class="bi bi-filetype-css me-1"></i>CSS
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="js-tab" data-bs-toggle="tab" data-bs-target="#js-editor" type="button">
                                    <i class="bi bi-filetype-js me-1"></i>JavaScript
                                </button>
                            </li>
                        </ul>
                    </div>

                    <!-- Editor Content -->
                    <div class="editor-content">
                        <div class="tab-content h-100">
                            <div class="tab-pane fade show active h-100" id="html-editor">
                                <textarea id="htmlEditor" class="code-editor"></textarea>
                            </div>
                            <div class="tab-pane fade h-100" id="css-editor">
                                <textarea id="cssEditor" class="code-editor"></textarea>
                            </div>
                            <div class="tab-pane fade h-100" id="js-editor">
                                <textarea id="jsEditor" class="code-editor"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Preview Panel -->
                <div class="col-3 preview-panel">
                    <div class="toolbar">
                        <h6 class="mb-0">Podgląd</h6>
                        <div class="ms-auto">
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-outline-secondary" id="refreshPreviewBtn" title="Odśwież podgląd">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary" id="previewOptionsBtn" title="Opcje podglądu">
                                    <i class="bi bi-gear"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <div class="h-100 position-relative">
                        <iframe id="previewIframe" class="preview-iframe" src="about:blank"></iframe>
                        <div id="previewLoading" class="position-absolute top-50 start-50 translate-middle" style="display: none;">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Ładowanie podglądu...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modals -->
    
    <!-- New Template Modal -->
    <div class="modal fade" id="newTemplateModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nowy szablon HTML</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="newTemplateForm">
                        <div class="mb-3">
                            <label for="templateName" class="form-label">Nazwa szablonu *</label>
                            <input type="text" class="form-control" id="templateName" required>
                        </div>
                        <div class="mb-3">
                            <label for="templateDescription" class="form-label">Opis</label>
                            <textarea class="form-control" id="templateDescription" rows="3"></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="templateCategory" class="form-label">Kategoria</label>
                            <select class="form-select" id="templateCategory">
                                <option value="general">Ogólne</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="templateTags" class="form-label">Tagi</label>
                            <input type="text" class="form-control" id="templateTags" placeholder="wino, karta, etykieta">
                            <div class="form-text">Oddziel tagi przecinkami</div>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="templatePublic">
                            <label class="form-check-label" for="templatePublic">
                                Publiczny szablon (dostępny dla wszystkich)
                            </label>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <button type="button" class="btn btn-primary" id="createTemplateBtn">Utwórz szablon</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Preview Options Modal -->
    <div class="modal fade" id="previewOptionsModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Opcje podglądu</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="previewFormat" class="form-label">Format PDF</label>
                        <select class="form-select" id="previewFormat">
                            <option value="A4">A4</option>
                            <option value="A5" selected>A5</option>
                            <option value="Letter">Letter</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="previewType" class="form-label">Typ podglądu</label>
                        <select class="form-select" id="previewType">
                            <option value="wine">Szablon wina</option>
                            <option value="collection">Szablon kolekcji</option>
                        </select>
                    </div>
                    <div class="mb-3" id="winePreviewOptions">
                        <label for="sampleWine" class="form-label">Przykładowe wino</label>
                        <select class="form-select" id="sampleWine">
                            <option value="">Losowe wino</option>
                        </select>
                    </div>
                    <div class="mb-3" id="collectionPreviewOptions" style="display: none;">
                        <label for="sampleCollection" class="form-label">Przykładowa kolekcja</label>
                        <select class="form-select" id="sampleCollection">
                            <option value="">Przykładowa kolekcja</option>
                        </select>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="previewBackground" checked>
                        <label class="form-check-label" for="previewBackground">
                            Drukuj tło i kolory
                        </label>
                    </div>
                    
                    <hr class="my-3">
                    <h6 class="mb-3">🎨 Personalizacja kolorów</h6>
                    
                    <div class="mb-3">
                        <label for="previewBgColor" class="form-label">Kolor tła</label>
                        <div class="input-group">
                            <input type="color" class="form-control form-control-color" id="previewBgColor" value="#f5f5f5" title="Wybierz kolor tła">
                            <input type="text" class="form-control" id="previewBgColorHex" value="#f5f5f5" placeholder="#f5f5f5">
                        </div>
                        <small class="text-muted">Ustaw kolor tła dla iframe preview</small>
                    </div>
                    
                    <div class="mb-3">
                        <label for="previewLinkColor" class="form-label">Kolor linków</label>
                        <div class="input-group">
                            <input type="color" class="form-control form-control-color" id="previewLinkColor" value="#0d6efd" title="Wybierz kolor linków">
                            <input type="text" class="form-control" id="previewLinkColorHex" value="#0d6efd" placeholder="#0d6efd">
                        </div>
                        <small class="text-muted">Ustaw kolor linków i elementów interaktywnych</small>
                    </div>
                    
                    <button type="button" class="btn btn-sm btn-outline-secondary w-100" id="resetColorsBtn">
                        <i class="bi bi-arrow-counterclockwise"></i> Resetuj kolory
                    </button>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zamknij</button>
                    <button type="button" class="btn btn-primary" id="applyPreviewOptionsBtn">Zastosuj</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Custom Format Modals -->
    
    <!-- Create/Edit Custom Format Modal -->
    <div class="modal fade" id="customFormatModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="customFormatModalTitle">Nowy format PDF</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="customFormatForm">
                        <div class="mb-3">
                            <label for="formatName" class="form-label">Nazwa formatu *</label>
                            <input type="text" class="form-control" id="formatName" required>
                            <div class="invalid-feedback"></div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="formatDescription" class="form-label">Opis</label>
                            <textarea class="form-control" id="formatDescription" rows="2" placeholder="Opcjonalny opis formatu"></textarea>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="formatWidth" class="form-label">Szerokość *</label>
                                    <input type="number" class="form-control" id="formatWidth" step="0.1" min="10" required>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="formatHeight" class="form-label">Wysokość *</label>
                                    <input type="number" class="form-control" id="formatHeight" step="0.1" min="10" required>
                                    <div class="invalid-feedback"></div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="formatUnit" class="form-label">Jednostka</label>
                            <select class="form-select" id="formatUnit">
                                <option value="mm">Milimetry (mm)</option>
                                <option value="pt">Punkty (pt)</option>
                                <option value="in">Cale (in)</option>
                            </select>
                        </div>
                        
                        <div class="mb-3">
                            <label for="formatOrientation" class="form-label">Orientacja</label>
                            <select class="form-select" id="formatOrientation">
                                <option value="portrait">Pionowa</option>
                                <option value="landscape">Pozioma</option>
                            </select>
                        </div>
                        
                        <h6 class="mb-3">Marginesy</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="marginTop" class="form-label">Góra</label>
                                    <input type="number" class="form-control" id="marginTop" step="0.1" min="0" value="20">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="marginBottom" class="form-label">Dół</label>
                                    <input type="number" class="form-control" id="marginBottom" step="0.1" min="0" value="20">
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="marginLeft" class="form-label">Lewo</label>
                                    <input type="number" class="form-control" id="marginLeft" step="0.1" min="0" value="20">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="marginRight" class="form-label">Prawo</label>
                                    <input type="number" class="form-control" id="marginRight" step="0.1" min="0" value="20">
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="formatActive" checked>
                            <label class="form-check-label" for="formatActive">
                                Format aktywny
                            </label>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <button type="button" class="btn btn-primary" id="saveCustomFormatBtn">Zapisz</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Custom Format Modal -->
    <div class="modal fade" id="deleteCustomFormatModal" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Usuń format</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Czy na pewno chcesz usunąć format <strong id="deleteFormatName"></strong>?</p>
                    <p class="text-muted small">Ta operacja jest nieodwracalna.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteFormatBtn">Usuń</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- CodeMirror Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/codemirror.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/mode/xml/xml.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/mode/css/css.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/mode/javascript/javascript.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/mode/htmlmixed/htmlmixed.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/addon/edit/closebrackets.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/addon/edit/closetag.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/addon/fold/foldcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/addon/fold/foldgutter.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/addon/fold/xml-fold.min.js"></script>
    
    <!-- Application Scripts -->
    <script src="js/api.js"></script>
    <script src="js/utils.js"></script>
    <script src="js/components/CustomFormatsManager.js"></script>
    <script src="js/components/TemplateEditor.js"></script>
</body>
</html>