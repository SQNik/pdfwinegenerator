<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wine Management System - System Zarządzania Kolekcją Win</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link href="css/style.css" rel="stylesheet">
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
</head>
<body>
    <!-- Navigation Container -->
    <div id="navigation-container"></div>

    <!-- Main Content -->
    <div class="container-fluid mt-3">
        <!-- Loading Indicator -->
        <div id="loading" class="text-center d-none">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Ładowanie...</span>
            </div>
        </div>

        <!-- Alert Container -->
        <div id="alert-container"></div>

        <!-- Dashboard Overview -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="jumbotron bg-primary text-white rounded p-5 mb-4">
                    <div class="container-fluid py-2">
                        <h1 class="display-5 fw-bold">System Zarządzania Winami</h1>
                        <p class="col-md-8 fs-4">Kompleksowe narzędzie do zarządzania kolekcją win z możliwością tworzenia kolekcji, generowania PDF i importu danych.</p>
                        <div class="row mt-4">
                            <div class="col-auto">
                                <a href="wines.html" class="btn btn-light btn-lg">
                                    <i class="bi bi-bottle me-2"></i>Zarządzaj Winami
                                </a>
                            </div>
                            <div class="col-auto">
                                <a href="collections.html" class="btn btn-outline-light btn-lg">
                                    <i class="bi bi-folder me-2"></i>Zarządzaj Kolekcjami
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h5 class="card-title">Łączna liczba win</h5>
                                <h2 class="mb-0" id="totalWines">0</h2>
                            </div>
                            <div class="align-self-center">
                                <i class="bi bi-bottle fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h5 class="card-title">Aktywne kolekcje</h5>
                                <h2 class="mb-0" id="totalCollections">0</h2>
                            </div>
                            <div class="align-self-center">
                                <i class="bi bi-folder fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h5 class="card-title">Szablony PDF</h5>
                                <h2 class="mb-0" id="totalTemplates">0</h2>
                            </div>
                            <div class="align-self-center">
                                <i class="bi bi-file-pdf fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h5 class="card-title">Ostatni import</h5>
                                <p class="mb-0" id="lastImport">Brak danych</p>
                            </div>
                            <div class="align-self-center">
                                <i class="bi bi-upload fs-1"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-lightning me-2"></i>Szybkie akcje</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="d-grid gap-2">
                                    <a href="wines.html" class="btn btn-outline-primary">
                                        <i class="bi bi-plus-circle me-2"></i>Dodaj nowe wino
                                    </a>
                                    <a href="collections.html" class="btn btn-outline-success">
                                        <i class="bi bi-folder-plus me-2"></i>Utwórz nową kolekcję
                                    </a>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-grid gap-2">
                                    <button class="btn btn-outline-info" onclick="showImportSection()">
                                        <i class="bi bi-upload me-2"></i>Importuj dane
                                    </button>
                                    <a href="pdf-templates.html" class="btn btn-outline-warning">
                                        <i class="bi bi-file-pdf me-2"></i>Zarządzaj szablonami PDF
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Import Section -->
        <div id="import-section" class="content-section d-none">
            <div class="row">
                <div class="col-lg-8 mx-auto">
                    <h2><i class="bi bi-upload"></i> Import Danych</h2>
                    
                    <div class="card">
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="importFile" class="form-label">Wybierz plik do importu</label>
                                <input type="file" class="form-control" id="importFile" accept=".json,.csv,.xlsx,.xls">
                                <div class="form-text">Obsługiwane formaty: JSON, CSV, Excel (.xlsx, .xls)</div>
                            </div>
                            
                            <div class="mb-3">
                                <label for="importType" class="form-label">Typ importu</label>
                                <select class="form-select" id="importType">
                                    <option value="wines">Wina</option>
                                </select>
                            </div>
                            
                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="replaceExisting">
                                    <label class="form-check-label" for="replaceExisting">
                                        Zastąp istniejące dane
                                    </label>
                                </div>
                            </div>
                            
                            <button type="button" class="btn btn-primary" id="startImport">
                                <i class="bi bi-upload"></i> Rozpocznij Import
                            </button>
                        </div>
                    </div>
                    
                    <div id="import-progress" class="card mt-3 d-none">
                        <div class="card-body">
                            <h6 class="card-title">Postęp importu</h6>
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                            </div>
                            <div class="mt-2" id="import-status"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Dashboard will focus on overview and quick access -->
            <!-- Zarządzanie polami win zostało przeniesione do wines.html -->
        </div>
    </div>

    <!-- Modałe win zostały przeniesione do wines.html -->

    <!-- Modal zarządzania polami win został przeniesiony do wines.html -->

    <!-- Modałe kolekcji zostały przeniesione do collections.html -->

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Application JS -->
    <script src="js/config.js"></script>
    <script src="js/config/wine-fields.js"></script>
    <script src="js/api.js"></script>
    <script src="js/utils.js"></script>
    <script src="js/config/NavigationConfig.js"></script>
    <script src="js/components/NavigationComponent.js"></script>
    <script src="js/components/import.js"></script>
    <script src="js/app.js"></script>
    
    <script>
        // Dashboard specific functionality
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize navigation using global configuration
            NavigationComponent.initGlobalNavigation('#navigation-container');
            // Initialize dashboard
            loadDashboardStats();
            
            // Function to show import section
            window.showImportSection = function() {
                // Navigate to import section in the same page
                const importSection = document.getElementById('import-section');
                if (importSection) {
                    // Show the import section
                    document.querySelectorAll('.content-section').forEach(section => {
                        section.classList.add('d-none');
                    });
                    importSection.classList.remove('d-none');
                    
                    // Scroll into view
                    importSection.scrollIntoView({ behavior: 'smooth' });
                }
            };
            
            // Load dashboard statistics
            async function loadDashboardStats() {
                try {
                    // Load wines count
                    const winesResponse = await fetch('/api/wines?limit=1');
                    if (winesResponse.ok) {
                        const winesData = await winesResponse.json();
                        if (winesData.success && winesData.pagination) {
                            document.getElementById('totalWines').textContent = winesData.pagination.total;
                        }
                    }
                    
                    // Load collections count
                    const collectionsResponse = await fetch('/api/collections');
                    if (collectionsResponse.ok) {
                        const collectionsData = await collectionsResponse.json();
                        if (collectionsData.success && collectionsData.data) {
                            const activeCollections = collectionsData.data.filter(c => c.status === 'active');
                            document.getElementById('totalCollections').textContent = activeCollections.length;
                        }
                    }
                    
                    // Load templates count (placeholder for now)
                    document.getElementById('totalTemplates').textContent = '3';
                    
                    // Set last import info
                    document.getElementById('lastImport').textContent = 'Nigdy';
                    
                } catch (error) {
                    console.error('Error loading dashboard stats:', error);
                }
            }
        });
    </script>
</body>
</html>