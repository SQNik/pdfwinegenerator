  {
    "id": "23306bdf-d566-4d9f-82c4-62c0fded45e2",
    "name": "Lista win z podziaL,em na kategorie",
    "description": "Szablon wyL>wietlaj�.cy wina pogrupowane wedL,ug kategorii (czerwone, biaL,e, rAlLLowe, musuj�.ce)",
    "category": "general",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Karta Win - PodziaL, na Kategorie</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    body {\n      font-family: 'Poppins', sans-serif;\n      background: #fff;\n      padding: 10mm;\n      font-size: 10pt;\n      line-height: 1.4;\n    }\n\n    /* NagL,Alwek kategorii */\n    .category-header {\n      background: #000;\n      color: #fff;\n      padding: 8mm 6mm;\n      margin: 6mm 0 4mm 0;\n      text-align: center;\n      font-size: 18pt;\n      font-weight: 700;\n      text-transform: uppercase;\n      letter-spacing: 2px;\n    }\n\n    .category-header:first-child {\n      margin-top: 0;\n    }\n\n    /* Lista win w kategorii */\n    .wine-list {\n      display: flex;\n      flex-direction: column;\n      gap: 4mm;\n      margin-bottom: 6mm;\n    }\n\n    /* Karta pojedynczego wina */\n    .wine-card {\n      display: grid;\n      grid-template-columns: 60px 1fr auto;\n      gap: 4mm;\n      padding: 4mm;\n      border: 1px solid #e0e0e0;\n      background: #fff;\n    }\n\n    /* Obrazek wina */\n    .wine-image {\n      display: flex;\n      align-items: flex-start;\n      justify-content: center;\n    }\n\n    .wine-image img {\n      max-width: 100%;\n      height: auto;\n      max-height: 80px;\n      object-fit: contain;\n    }\n\n    /* TreL>�? wina */\n    .wine-content {\n      display: flex;\n      flex-direction: column;\n      gap: 2mm;\n    }\n\n    .wine-title {\n      font-size: 12pt;\n      font-weight: 700;\n      color: #1a1a1a;\n      line-height: 1.2;\n      margin-bottom: 1mm;\n    }\n\n    .wine-info {\n      font-size: 9pt;\n      color: #333;\n      line-height: 1.3;\n    }\n\n    .wine-info strong {\n      font-weight: 600;\n      color: #000;\n    }\n\n    .wine-description {\n      font-size: 8pt;\n      color: #555;\n      line-height: 1.4;\n      margin-top: 1mm;\n    }\n\n    .wine-alcohol {\n      font-size: 7pt;\n      color: #999;\n      margin-top: 1mm;\n    }\n\n    /* Ceny */\n    .wine-prices {\n      display: flex;\n      flex-direction: column;\n      gap: 2mm;\n      align-items: flex-end;\n      justify-content: flex-start;\n    }\n\n    .price-row {\n      display: flex;\n      align-items: center;\n      gap: 2mm;\n    }\n\n    .price-label {\n      font-size: 8pt;\n      color: #666;\n      white-space: nowrap;\n    }\n\n    .price-amount {\n      font-size: 10pt;\n      font-weight: 700;\n      color: #1a1a1a;\n      border: 1px solid #000;\n      border-radius: 2mm;\n      padding: 2mm 4mm;\n      min-width: 50px;\n      text-align: center;\n    }\n\n    /* PodziaL, stron */\n    .page-break {\n      page-break-after: always;\n    }\n\n    @media print {\n      body {\n        padding: 0;\n      }\n      .category-header {\n        page-break-inside: avoid;\n      }\n      .wine-card {\n        page-break-inside: avoid;\n      }\n    }\n  </style>\n</head>\n<body>\n\n  {{#if collection.dynamicFieldsByName.tytul}}\n  <h1 style=\"text-align: center; font-size: 24pt; margin-bottom: 10mm;\">{{collection.dynamicFieldsByName.tytul}}</h1>\n  {{/if}}\n\n  {{#each collection.winesByCategory}}\n    <div class=\"category-header\">{{@key}}</div>\n    <div class=\"wine-list\">\n      {{#each this}}\n      <div class=\"wine-card\">\n        <!-- Obrazek -->\n        <div class=\"wine-image\">\n          <img src=\"https://witrynarium.pl{{this.image}}\" alt=\"{{this.name}}\">\n        </div>\n\n        <!-- TreL>�? -->\n        <div class=\"wine-content\">\n          <h2 class=\"wine-title\">{{this.name}}</h2>\n          \n          <div class=\"wine-info\"><strong>Szczep:</strong> {{this.szczepy}}</div>\n          <div class=\"wine-info\"><strong>Region:</strong> {{this.region}}</div>\n          <div class=\"wine-info\"><strong>Typ:</strong> {{this.type}}</div>\n          \n          {{#if this.description}}\n          <p class=\"wine-description\">{{this.description}}</p>\n          {{/if}}\n          \n          {{#if this.alcohol}}\n          <div class=\"wine-alcohol\">Vol: {{this.alcohol}}</div>\n          {{/if}}\n        </div>\n\n        <!-- Ceny -->\n        <div class=\"wine-prices\">\n          {{#if this.price1}}\n          <div class=\"price-row\">\n            <span class=\"price-label\">150ml</span>\n            <span class=\"price-amount\">{{this.price1}}</span>\n          </div>\n          {{/if}}\n          \n          {{#if this.price2}}\n          <div class=\"price-row\">\n            <span class=\"price-label\">750ml</span>\n            <span class=\"price-amount\">{{this.price2}}</span>\n          </div>\n          {{/if}}\n        </div>\n      </div>\n      {{/each}}\n    </div>\n  {{/each}}\n\n</body>\n</html>",
