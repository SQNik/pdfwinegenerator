  {
    "id": "header-4plus5-cmyk-2025",
    "name": "Nagłówek + 4/5 produktów CMYK (109×301mm)",
    "description": "Szablon z kolorystyką CMYK przygotowany do druku profesjonalnego. Wymiary 109mm × 301mm. Pierwsza strona: nagłówek + 4 produkty. Kolejne strony: po 5 produktów. Wszystkie kolory w przestrzeni CMYK.",
    "htmlContent": "<!DOCTYPE html>\r\n<html lang=\"pl\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"pagination\" content=\"firstPage:4,nextPages:5\">\r\n  <title>Karta Wina - Nagłówek + 4/5 produktów (CMYK)</title>\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\r\n  <style>\r\n    * {\r\n      margin: 0;\r\n      padding: 0;\r\n      box-sizing: border-box;\r\n    }\r\n\r\n    body {\r\n      font-family: 'Poppins', sans-serif;\r\n      background: device-cmyk(0%, 0%, 0%, 0%); /* Biały w CMYK */\r\n      color: device-cmyk(0%, 0%, 0%, 100%); /* Czarny w CMYK */\r\n      font-size: 9pt;\r\n      line-height: 1.3;\r\n      margin: 0;\r\n      padding: 0;\r\n    }\r\n\r\n    /* === PIERWSZA STRONA - NAGŁÓWEK + 4 PRODUKTY === */\r\n    .first-page {\r\n      width: 109mm;\r\n      height: 301mm;\r\n      page-break-after: always;\r\n      display: flex;\r\n      flex-direction: column;\r\n      background: {{collection.dynamicFieldsByName.kolor_okladki}};\r\n      background-image: url('{{collection.dynamicFieldsByName.tlo_okladki}}');\r\n      background-size: contain;\r\n    }\r\n\r\n    /* Nagłówek - 20% wysokości */\r\n    .page-header {\r\n      height: 20%;\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n      background-size: cover;\r\n      background-position: center;\r\n      padding: 4mm;\r\n      border-bottom: 1px dashed device-cmyk(0%, 0%, 0%, 13%); /* Jasny szary */\r\n    }\r\n\r\n    .header-title {\r\n      font-size: 24pt;\r\n      font-weight: 700;\r\n      color: device-cmyk(0%, 0%, 0%, 100%); /* Czarny CMYK */\r\n      text-align: center;\r\n    }\r\n\r\n    /* Produkty na pierwszej stronie - 80% wysokości / 4 = 20% każdy */\r\n    .first-page-products {\r\n      height: 80%;\r\n      display: flex;\r\n      flex-direction: column;\r\n    }\r\n\r\n    .first-page-products .wine-card {\r\n      height: 25%; /* 80% / 4 = 20% każdy produkt */\r\n      flex-shrink: 0;\r\n    }\r\n\r\n    /* === KOLEJNE STRONY - 5 PRODUKTÓW === */\r\n    .products-page {\r\n      width: 109mm;\r\n      height: 301mm;\r\n      page-break-after: always;\r\n      display: flex;\r\n      flex-direction: column;\r\n      background: {{collection.dynamicFieldsByName.kolor_listy}};\r\n      background-image: url(\"{{collection.dynamicFieldsByName.tlo_listy}}\");\r\n      background-size: contain;\r\n      background-position: top;\r\n    }\r\n\r\n    .products-page .wine-card {\r\n      height: 20%; /* 100% / 5 = 20% każdy produkt */\r\n      flex-shrink: 0;\r\n    }\r\n\r\n    /* === KARTA PRODUKTU === */\r\n    .wine-card {\r\n      display: grid;\r\n      grid-template-columns: 15% 85%; /* 15% obraz, 85% treść */\r\n      gap: 1mm;\r\n      padding: 6mm;\r\n      border: 0px solid device-cmyk(0%, 0%, 0%, 13%);\r\n      overflow: hidden;\r\n    }\r\n\r\n    /* Lewa strona - Obraz */\r\n    .wine-image {\r\n      display: flex;\r\n      align-items: flex-start;\r\n      justify-content: flex-start;\r\n      padding-right: 0mm;\r\n    }\r\n\r\n    .wine-image img {\r\n      max-width: 100%;\r\n      height: auto;\r\n      object-fit: cover;\r\n    }\r\n\r\n    /* Prawa strona - Treść */\r\n    .wine-content {\r\n      display: flex;\r\n      flex-direction: column;\r\n      gap: 2mm;\r\n    }\r\n\r\n    /* Wiersz nagłówka - Nazwa i Ceny */\r\n    .wine-header-row {\r\n      display: flex;\r\n      justify-content: space-between;\r\n      align-items: flex-start;\r\n      gap: 4mm;\r\n    }\r\n\r\n    .wine-title {\r\n      font-size: 12pt;\r\n      font-weight: 700;\r\n      line-height: 1.2;\r\n      color: device-cmyk(0%, 0%, 0%, 90%); /* Prawie czarny */\r\n      text-transform: uppercase;\r\n      letter-spacing: -0.5px;\r\n      flex: 1;\r\n    }\r\n\r\n    .wine-prices {\r\n      display: flex;\r\n      gap: 2mm;\r\n      flex-shrink: 0;\r\n      flex-direction: column;\r\n    }\r\n\r\n    .price-badge {\r\n      display: flex;\r\n      align-items: center;\r\n      gap: 0mm;\r\n      font-weight: 600;\r\n      white-space: nowrap;\r\n      justify-content: flex-end;\r\n    }\r\n\r\n    .price-amount {\r\n      text-align: right;\r\n      font-size: 10pt;\r\n      font-weight: bold;\r\n      color: device-cmyk(0%, 0%, 0%, 90%); /* Prawie czarny */\r\n      border: 1px solid device-cmyk(0%, 0%, 0%, 90%);\r\n      border-radius: 1mm;\r\n      padding: 2px 12px;\r\n      flex: 1;\r\n    }\r\n\r\n    /* Szczegóły wina */\r\n    .wine-details {\r\n      display: flex;\r\n      flex-direction: column;\r\n      gap: 0.5mm;\r\n    }\r\n\r\n    .wine-detail-item {\r\n      display: block;\r\n      font-size: 8pt;\r\n      color: device-cmyk(0%, 0%, 0%, 70%); /* Ciemny szary */\r\n      line-height: 1.3;\r\n    }\r\n\r\n    .wine-detail-label {\r\n      font-weight: 600;\r\n      display: inline;\r\n      color: device-cmyk(0%, 0%, 0%, 100%); /* Czarny dla etykiet */\r\n    }\r\n\r\n    .wine-detail-value {\r\n      font-weight: 400;\r\n      display: inline;\r\n    }\r\n\r\n    .wine-description {\r\n      font-size: 8pt;\r\n      line-height: 1.3;\r\n      margin-top: 1mm;\r\n      color: device-cmyk(0%, 0%, 0%, 70%); /* Ciemny szary */\r\n      max-height: 20mm;\r\n      overflow: hidden;\r\n      text-overflow: ellipsis;\r\n      display: -webkit-box;\r\n      -webkit-line-clamp: 3;\r\n      -webkit-box-orient: vertical;\r\n    }\r\n\r\n    .wine-alcohol {\r\n      font-size: 6pt;\r\n      font-weight: 600;\r\n      color: device-cmyk(0%, 0%, 0%, 40%); /* Jasny szary */\r\n      margin-top: 1mm;\r\n    }\r\n    \r\n    .litry {\r\n      font-size: 6pt;\r\n      color: device-cmyk(0%, 0%, 0%, 40%); /* Jasny szary */\r\n      font-weight: 400;\r\n    }\r\n    \r\n    .icon_wine {\r\n      background-image: url(http://witrynarium.pl/images/icons/wine.svg);\r\n      width: 24px;\r\n      height: 24px;\r\n      display: inline-block;\r\n      /* Cyan/niebieski w CMYK */\r\n      color: device-cmyk(80%, 40%, 0%, 0%);\r\n    }\r\n    \r\n    .icon_glass {\r\n      background-image: url(http://witrynarium.pl/images/icons/glass.svg);\r\n      width: 24px;\r\n      height: 24px;\r\n      display: inline-block;\r\n      color: device-cmyk(0%, 0%, 0%, 40%); /* Jasny szary */\r\n    }\r\n\r\n    /* Wymuszenie nowej strony */\r\n    @media print {\r\n      .first-page,\r\n      .products-page {\r\n        page-break-after: always;\r\n      }\r\n    }\r\n  </style>\r\n</head>\r\n<body>\r\n\r\n  <!-- PIERWSZA STRONA - NAGŁÓWEK + 4 PRODUKTY -->\r\n  <div class=\"first-page\">\r\n    <!-- Nagłówek z tłem z dynamicznego pola -->\r\n    <div class=\"page-header\" style=\"background-image: url('{{collection.dynamicFieldsByName.zwykly_tekst}}');\">\r\n      <h1 class=\"header-title\">{{collection.dynamicFieldsByName.Tytul}}</h1>\r\n    </div>\r\n\r\n    <!-- Pierwsze 4 produkty -->\r\n    <div class=\"first-page-products\">\r\n      {{#each firstPageWines}}\r\n      <div class=\"wine-card\">\r\n        <!-- Lewa strona - Obraz -->\r\n        <div class=\"wine-image\">\r\n          <img src=\"https://witrynarium.pl{{this.image}}\" alt=\"{{this.name}}\">\r\n        </div>\r\n\r\n        <!-- Prawa strona - Treść -->\r\n        <div class=\"wine-content\">\r\n          <!-- Nagłówek - Nazwa i Ceny -->\r\n          <div class=\"wine-header-row\">\r\n            <h2 class=\"wine-title\">{{this.name}}</h2>\r\n            \r\n            <div class=\"wine-prices\">\r\n              <div class=\"price-badge\">\r\n                <span class=\"litry\">150ml</span><span class=\"icon_glass\"></span><span class=\"price-amount\">{{this.price1}}</span>\r\n              </div>\r\n              <div class=\"price-badge\">\r\n                <span class=\"litry\">750ml</span><span class=\"icon_wine\"></span><span class=\"price-amount\">{{this.price2}}</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <!-- Szczegóły -->\r\n          <div class=\"wine-details\">\r\n            <div class=\"wine-detail-item\">\r\n              <span class=\"wine-detail-label\">Szczep:</span>\r\n              <span class=\"wine-detail-value\">{{this.szczepy}}</span>\r\n            </div>\r\n            \r\n            <div class=\"wine-detail-item\">\r\n              <span class=\"wine-detail-label\">Region:</span>\r\n              <span class=\"wine-detail-value\">{{this.region}}</span>\r\n            </div>\r\n            \r\n            <div class=\"wine-detail-item\">\r\n              <span class=\"wine-detail-label\">Typ:</span>\r\n              <span class=\"wine-detail-value\">{{this.type}}</span>\r\n            </div>\r\n\r\n            <div class=\"wine-detail-item\">\r\n              <span class=\"wine-detail-label\">Kolor:</span>\r\n              <span class=\"wine-detail-value\">{{this.category}}</span>\r\n            </div>\r\n            \r\n            <p class=\"wine-description\">{{this.description}}</p>\r\n            \r\n            <div class=\"wine-alcohol\">Vol: {{this.alcohol}}</div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      {{/each}}\r\n    </div>\r\n  </div>\r\n\r\n  <!-- KOLEJNE STRONY - PO 5 PRODUKTÓW -->\r\n  {{#each restPages}}\r\n  <div class=\"products-page\">\r\n    {{#each this}}\r\n    <div class=\"wine-card\">\r\n      <!-- Lewa strona - Obraz -->\r\n      <div class=\"wine-image\">\r\n        <img src=\"https://witrynarium.pl{{this.image}}\" alt=\"{{this.name}}\">\r\n      </div>\r\n\r\n      <!-- Prawa strona - Treść -->\r\n      <div class=\"wine-content\">\r\n        <!-- Nagłówek - Nazwa i Ceny -->\r\n        <div class=\"wine-header-row\">\r\n          <h2 class=\"wine-title\">{{this.name}}</h2>\r\n          \r\n          <div class=\"wine-prices\">\r\n            <div class=\"price-badge\">\r\n              <span class=\"litry\">150ml</span><span class=\"icon_glass\"></span><span class=\"price-amount\">{{this.price1}}</span>\r\n            </div>\r\n            <div class=\"price-badge\">\r\n              <span class=\"litry\">750ml</span><span class=\"icon_wine\"></span><span class=\"price-amount\">{{this.price2}}</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Szczegóły -->\r\n        <div class=\"wine-details\">\r\n          <div class=\"wine-detail-item\">\r\n            <span class=\"wine-detail-label\">Szczep:</span>\r\n            <span class=\"wine-detail-value\">{{this.szczepy}}</span>\r\n          </div>\r\n          \r\n          <div class=\"wine-detail-item\">\r\n            <span class=\"wine-detail-label\">Region:</span>\r\n            <span class=\"wine-detail-value\">{{this.region}}</span>\r\n          </div>\r\n          \r\n          <div class=\"wine-detail-item\">\r\n            <span class=\"wine-detail-label\">Typ:</span>\r\n            <span class=\"wine-detail-value\">{{this.type}}</span>\r\n          </div>\r\n\r\n          <div class=\"wine-detail-item\">\r\n            <span class=\"wine-detail-label\">Kolor:</span>\r\n            <span class=\"wine-detail-value\">{{this.category}}</span>\r\n          </div>\r\n          \r\n          <p class=\"wine-description\">{{this.description}}</p>\r\n          \r\n          <div class=\"wine-alcohol\">Vol: {{this.alcohol}}</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    {{/each}}\r\n  </div>\r\n  {{/each}}\r\n\r\n</body>\r\n</html>\r\n",
    "metadata": {
      "layout": "single-column",
