  {
    "id": "f97ed712-f93a-48d8-af84-9ff778043b28",
    "name": "Edytowalny",
    "description": "",
    "category": "general",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"editable-fields\" content=\"enabled\">\n    <title>Karta Win z Edytowalnymi Cenami</title>\n    <style>\n        @page {\n            size: 210mm 297mm; /* A4 */\n            margin: 15mm;\n        }\n        \n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Segoe UI', Arial, sans-serif;\n            font-size: 10pt;\n        }\n        \n        .header {\n            text-align: center;\n            margin-bottom: 20mm;\n            border-bottom: 2px solid #333;\n            padding-bottom: 5mm;\n        }\n        \n        .header h1 {\n            margin: 0;\n            font-size: 24pt;\n            color: #721c24;\n        }\n        \n        .header p {\n            margin: 3mm 0 0 0;\n            color: #666;\n            font-size: 11pt;\n        }\n        \n        .wine-table {\n            width: 100%;\n            border-collapse: collapse;\n        }\n        \n        .wine-table th {\n            background: #721c24;\n            color: white;\n            padding: 3mm;\n            text-align: left;\n            font-size: 10pt;\n        }\n        \n        .wine-table td {\n            padding: 3mm;\n            border-bottom: 1px solid #ddd;\n            vertical-align: top;\n        }\n        \n        .wine-row {\n            page-break-inside: avoid;\n        }\n        \n        .wine-name {\n            font-weight: bold;\n            color: #333;\n            font-size: 11pt;\n        }\n        \n        .wine-code {\n            color: #999;\n            font-size: 9pt;\n            margin-top: 1mm;\n        }\n        \n        .wine-details {\n            color: #666;\n            font-size: 9pt;\n            line-height: 1.4;\n            margin-top: 2mm;\n        }\n        \n        .wine-category {\n            display: inline-block;\n            padding: 1mm 3mm;\n            background: #f0f0f0;\n            border-radius: 2mm;\n            font-size: 8pt;\n            margin-right: 2mm;\n        }\n        \n        /* EDYTOWALNE POLE CENY */\n        .editable-price-field {\n            position: relative;\n            display: inline-block;\n            min-width: 60px;\n            height: 20px;\n            background: #fffef0; /* Lekko żółte tło */\n            border: 1px solid #999;\n            border-radius: 2px;\n            padding: 2px 5px;\n            text-align: right;\n            font-size: 10pt;\n            font-family: 'Courier New', monospace;\n        }\n        \n        .editable-price-field::before {\n            content: '✎'; /* Ikona ołówka */\n            position: absolute;\n            left: 2px;\n            top: 2px;\n            font-size: 8pt;\n            color: #999;\n        }\n        \n        .price-placeholder {\n            color: #bbb;\n            font-style: italic;\n        }\n        \n        .footer {\n            position: fixed;\n            bottom: 10mm;\n            left: 15mm;\n            right: 15mm;\n            text-align: center;\n            font-size: 8pt;\n            color: #999;\n            border-top: 1px solid #ddd;\n            padding-top: 3mm;\n        }\n    </style>\n</head>\n<body>\n    <!-- NAGŁÓWEK -->\n    <div class=\"header\">\n        <h1>{{collection.name}}</h1>\n        <p>{{collection.description}}</p>\n        <p style=\"font-size: 9pt; color: #999;\">\n            Wypełnij ceny w polach edytowalnych • Zapisz PDF po wypełnieniu\n        </p>\n    </div>\n    \n    <!-- TABELA WIN -->\n    <table class=\"wine-table\">\n        <thead>\n            <tr>\n                <th style=\"width: 8%;\">Kod</th>\n                <th style=\"width: 52%;\">Nazwa i Opis</th>\n                <th style=\"width: 20%;\">Szczegóły</th>\n                <th style=\"width: 20%;\">Cena</th>\n            </tr>\n        </thead>\n        <tbody>\n           {{#each winePages}}\n            {{#each this}}\n            <tr class=\"wine-row\">\n                <!-- KOD -->\n                <td>\n                    <div style=\"font-weight: bold; font-size: 10pt;\">\n                        {{this.catalogNumber}}\n                    </div>\n                </td>\n                \n                <!-- NAZWA I OPIS -->\n                <td>\n                    <div class=\"wine-name\">{{this.name}}</div>\n                    <div class=\"wine-details\">{{this.description}}</div>\n                </td>\n                \n                <!-- SZCZEGÓŁY -->\n                <td>\n                    <div class=\"wine-category\" style=\"background: #f8d7da; color: #721c24;\">\n                        {{this.category}}\n                    </div>\n                    <div style=\"margin-top: 2mm; font-size: 9pt;\">\n                        <div><strong>Region:</strong> {{this.region}}</div>\n                        <div><strong>Szczepy:</strong> {{this.szczepy}}</div>\n                        <div><strong>Alkohol:</strong> {{this.alcohol}}</div>\n                        <div><strong>Poj.:</strong> {{this.poj}}</div>\n                    </div>\n                </td>\n                \n                <!-- EDYTOWALNA CENA -->\n                <td style=\"text-align: right;\">\n                    <div class=\"editable-price-field\"\n                         data-editable-price=\"wine_{{this.catalogNumber}}_price\"\n                         data-price-x=\"470\"\n                         data-price-y=\"{{math @index '*' 95 '+' 145}}\"\n                         data-price-width=\"75\"\n                         data-price-height=\"22\">\n                        <span class=\"price-placeholder\">_____ zł</span>\n                    </div>\n                    \n                    <!-- Pole dla ceny hurtowej (opcjonalne) -->\n                    <div style=\"margin-top: 3mm; font-size: 8pt; color: #666;\">\n                        Hurtowa:\n                        <div class=\"editable-price-field\"\n                             style=\"min-width: 50px; font-size: 8pt;\"\n                             data-editable-price=\"wine_{{this.catalogNumber}}_wholesale\"\n                             data-price-x=\"485\"\n                             data-price-y=\"{{math @index '*' 95 '+' 165}}\"\n                             data-price-width=\"60\"\n                             data-price-height=\"18\">\n                            <span class=\"price-placeholder\">____ zł</span>\n                        </div>\n                    </div>\n                </td>\n            </tr>\n            {{/each}} {{/each}}\n        </tbody>\n    </table>\n    \n    <!-- STOPKA -->\n    <div class=\"footer\">\n        Karta win wygenerowana {{date}} • Ceny do uzupełnienia • {{collection.name}}\n    </div>\n    \n    <!-- SKRYPT POMOCNICZY (tylko w development) -->\n    <script>\n        // Ten skrypt pomaga wyznaczać pozycje pól - usunąć w produkcji\n        if (window.location.hostname === 'localhost') {\n            document.addEventListener('DOMContentLoaded', function() {\n                console.log('=== POZYCJE PÓL EDYTOWALNYCH ===');\n                \n                const priceFields = document.querySelectorAll('[data-editable-price]');\n                \n                priceFields.forEach((field, index) => {\n                    const rect = field.getBoundingClientRect();\n                    const name = field.getAttribute('data-editable-price');\n                    \n                    console.log(`Pole ${index + 1}: ${name}`, {\n                        x: Math.round(rect.left),\n                        y: Math.round(rect.top),\n                        width: Math.round(rect.width),\n                        height: Math.round(rect.height)\n                    });\n                    \n                    // Automatycznie ustaw atrybuty jeśli brakuje\n                    if (!field.hasAttribute('data-price-x')) {\n                        field.setAttribute('data-price-x', Math.round(rect.left));\n                        field.setAttribute('data-price-y', Math.round(rect.top));\n                        field.setAttribute('data-price-width', Math.round(rect.width));\n                        field.setAttribute('data-price-height', Math.round(rect.height));\n                        \n                        console.log(`  ✅ Auto-set coordinates for ${name}`);\n                    }\n                });\n                \n                console.log('=== KONIEC LISTY ===');\n            });\n        }\n    </script>\n</body>\n</html>\n",
    "cssContent": "/* Dodatkowe style CSS */\n.wine-card:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 8px 15px rgba(0,0,0,0.15);\n    transition: all 0.3s ease;\n}\n\n@media print {\n    body {\n        background: white;\n    }\n    \n    .wine-card {\n        box-shadow: none;\n        border: 1px solid #ddd;\n    }\n}",
