  {
    "id": "966b84b1-f739-4b18-9624-e17bbddd5f6e",
    "name": "Test kolekcji podzielony na kategorie",
    "description": "",
    "category": "general",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Karta Wina</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Poppins', sans-serif;\n            background: #f5f5f5;\n            padding: 0px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n           \n        }\n\n        .wine-card {\n            background: white;\n            border-radius: 0px;\n          border:1px solid #ddd;   \n            width: 100%;\n          \n            overflow: hidden;\n          padding:8px;\n          padding-bottom:8px;\n        }\n\n        .wine-card-inner {\n            display: grid;\n            grid-template-columns: 15% 85%;\n            gap: 8px;\n            padding: 8px;\n        }\n\n        /* Left side - Image (20%) */\n        .wine-image {\n            display: flex;\n            align-items: flex-start;\n            justify-content: center;\n        }\n\n        .wine-image img {\n            max-width: 100%;\n            height: auto;\n            \n            object-fit: contain;\n        }\n\n        /* Right side - Content (80%) */\n        .wine-content {\n            display: flex;\n            flex-direction: column;\n            gap: 0px;\n        }\n\n        /* Row 1 - Title and Prices */\n        .wine-header-row {\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-start;\n            gap: 24px;\n            \n        }\n\n        .wine-title {\n            font-size: 12pt;\n            font-weight: 700;\n            line-height: 1.3;\n            color: #1a1a1a;\n            text-transform: uppercase;\n            letter-spacing: -0.5px;\n            flex: 1;\n        }\n\n        .wine-prices {\n        display: flex\n;\n    gap: 4px;\n    flex-shrink: 0;\n    flex-direction: column;\n\n        }\n\n        .price-badge {\n    display: flex;\n    align-items: center;\n    gap: 0px;\n    background: white;\n    font-weight: 600;\n    white-space: nowrap;\n    justify-content: flex-end;\n        }\n\n        .price-volume {\n            font-size: 6pt;\n            color: #666;\n            display: flex;\n            align-items: center;\n            gap: 0px;\n          \n        }\n\n        .price-amount {\n            font-size: 10pt;\n            color: #1a1a1a;\n          border: 2px solid #1a1a1a;\n          border-radius: 24px;\n          padding: 4px 16px\n        }\n\n        /* Row 2 - Details (one under another) */\n        .wine-details {\n            display: flex;\n            flex-direction: column;\n            gap: 0px;\n        }\n\n        .wine-detail-item {\n            font-size: 8pt;\n            color: #2c2c2c;\n            line-height: 1.5;\n        }\n\n        .wine-detail-label {\n            font-weight: 600;\n            display: inline;\n        }\n\n        .wine-detail-value {\n            font-weight: 400;\n            display: inline;\n        }\n\n        .wine-description {\n            font-size: 8pt;\n            line-height: 1.4;\n            color: #2c2c2c;\n            text-align: justify;\n          margin-top:8px;\n          margin-bottom:8px;\n          max-height:30px;\n            -webkit-line-clamp: 3; /* liczba widocznych linii */\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n     \n        }\n\n        .wine-alcohol {\n            font-size: 6pt;\n            font-weight: 600;\n            color: #2c2c2c;\n        }\n \n    \n     .category h1{\n    background:#000000;\n      color:#ffffff;\n       font-size:14pt;\n      padding:16px;\n      margin-top:0px;\n       margin-bottom:0px;\n     line-height:16px;\n       }\n  \n    </style>\n</head>\n<body>\n\n\n\n{{#each collection.winesByCategory}}\n \n  <div class=\"category\">\n    <h1 style=\"text-align:center;\">Wina {{category}}</h1>\n       \n\n    <div class=\"wine-card\">\n       {{#each wines}}\n        <div class=\"wine-card-inner\">\n            <!-- Left side - Wine image (20%) -->\n            <div class=\"wine-image\">\n                <img src=\"https://witrynarium.pl{{wine.image}}\" alt=\"\">\n            </div>\n\n            <!-- Right side - Wine info (80%) -->\n            <div class=\"wine-content\">\n                <!-- Row 1 - Title and Prices in one row -->\n                <div class=\"wine-header-row\">\n                    <h2 class=\"wine-title\">{{wine.name}}</h2>\n                    \n                    <div class=\"wine-prices\">\n                        <div class=\"price-badge\">\n                          <span class=\"price-volume\">100ml <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\"><title>wine-glass-france-french-nation-holiday</title><g fill=\"#454444\"><path d=\"M18.43 9.1c-0.19-1.55-1.47-5.92-1.53-6.11a0.19 0.19 0 0 0-0.18-0.14h-9.12a0.19 0.19 0 0 0-0.18 0.14c-0.05 0.19-1.33 4.56-1.53 6.11-0.18 1.46 0.29 2.91 1.33 4.08 1.18 1.34 2.94 2.15 4.75 2.2v5.71h-3.61a0.19 0.19 0 0 0 0 0.38h7.6a0.19 0.19 0 0 0 0-0.38h-3.61v-5.71c1.8-0.05 3.57-0.86 4.75-2.2 1.04-1.17 1.51-2.62 1.33-4.08z m-10.69-5.87h8.84a116.49 116.49 0 0 1 0.93 3.42h-10.7c0.37-1.45 0.8-2.96 0.93-3.42z m9.07 9.7c-1.15 1.3-2.89 2.08-4.65 2.08s-3.5-0.78-4.65-2.08c-0.97-1.09-1.4-2.44-1.24-3.79 0.06-0.48 0.23-1.27 0.44-2.11h10.9c0.21 0.84 0.38 1.63 0.44 2.11 0.17 1.35-0.27 2.69-1.24 3.79z\" id=\"nccpEbene_1\"></path></g></svg><title>wine-glass-france-french-nation-holiday</title><g fill=\"#454444\"><path d=\"M48.496 23.939c-.503-4.086-3.873-15.592-4.017-16.08A.498.498 0 0 0 44 7.5H20a.5.5 0 0 0-.48.359c-.143.488-3.513 11.994-4.016 16.08-.473 3.84