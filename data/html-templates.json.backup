  {
    "id": "grid-2x5-template-2025",
    "name": "Karta składana na pół_v1-2kolumny-5produktow",
    "description": "Układ grafiki wina: w pionie\nSzablon z pełną okładką oraz stronami z produktami w siatce 2 kolumny × 5 wierszy. Dokładnie 10 produktów na stronę, wypełnianie kolumnowe (lewa 1-5, prawa 6-10).",
    "category": "general",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Karta Wina - 2 kolumny x 5 produktów</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    body {\n      font-family: 'Poppins', sans-serif;\n      background: #fff;\n      font-size: 10pt;\n      line-height: 1.4;\n      margin: 0;\n      padding: 0;\n    }\n\n    /* === OKŁADKA - PEŁNA STRONA === */\n    .cover-page {\n      width: 100%;\n      height: 100vh;\n      background-size: cover;\n      background-position: center;\n      page-break-after: always;\n      display: flex;\n      gap:4mm;\n      align-items: center;\n      justify-content: center;\n      background:{{collection.dynamicFieldsByName.kolor_okladki}};\n      background-image: url('{{collection.dynamicFieldsByName.tlo_okladki}}');\n      background-size:contain;\n      \n    }\n\n    /* === STRONA PRODUKTÓW - GRID 2 KOLUMNY x 5 WIERSZY === */\n    .products-page {\n      width: 214mm;\n      height: 301mm;\n      padding: 6mm 0;\n      page-break-after: always;\n      display: grid;\n      grid-template-columns: 1fr 1fr; /* 2 równe kolumny */\n      grid-template-rows: repeat(5, 1fr); /* 5 równych wierszy */\n      grid-auto-flow: column; /* 🔥 WYPEŁNIAJ KOLUMNAMI: lewa 1-5, prawa 6-10 */\n      gap: 0;\n      background:{{collection.dynamicFieldsByName.kolor_listy}};\n      background-image: url(\"{{collection.dynamicFieldsByName.tlo_listy}}\");\n      background-size: contain;\n      background-position: top;\n    }\n\n    /* === KARTA PRODUKTU - IDEALNIE 1/5 WYSOKOŚCI KOLUMNY === */\n    .wine-card {\n      display: grid;\n      grid-template-columns: 15% 85%; /* 15% obraz, 85% treść */\n      gap: 1mm;\n      padding: 6mm;\n      border: 0px solid #ddd;\n      overflow: hidden;\n    }\n\n    /* Lewa strona - Obraz */\n    .wine-image {\n      display: flex;\n      align-items: flex-start;\n      justify-content: flex-start;\n      padding-right: 0mm;\n    }\n\n    .wine-image img {\n      max-width: 100%;\n      height: auto;\n      object-fit: cover;\n    }\n\n    /* Prawa strona - Treść */\n    .wine-content {\n      display: flex;\n      flex-direction: column;\n      gap: 2mm;\n    }\n\n    /* Wiersz nagłówka - Nazwa i Ceny */\n    .wine-header-row {\n      display: flex;\n      justify-content: space-between;\n      align-items: flex-start;\n      gap: 4mm;\n    }\n\n    .wine-title {\n      font-size: 12pt;\n      font-weight: 700;\n      line-height: 1.2;\n      color: #1a1a1a;\n      text-transform: uppercase;\n      letter-spacing: -0.5px;\n      flex: 1;\n    }\n\n    .wine-prices {\n      display: flex;\n      gap: 2mm;\n      flex-shrink: 0;\n      flex-direction: column;\n    }\n\n    .price-badge {\n      display: flex;\n      align-items: center;\n      gap: 0mm;\n      font-weight: 600;\n      white-space: nowrap;\n      justify-content: flex-end;\n    }\n\n    .price-amount {\n      text-align: right;\n      font-size: 10pt;\n       font-weight: bold;\n      color: #1a1a1a;\n      border: 1px solid #1a1a1a;\n      border-radius: 1mm;\n      padding: 2px 12px;\n      flex:1;\n    }\n\n    /* Szczegóły wina */\n    .wine-details {\n      display: flex;\n      flex-direction: column;\n      gap: 0.5mm;\n    }\n\n    .wine-detail-item {\n      display: block;\n      font-size: 8pt;\n      color: #333333;\n      line-height: 1.3;\n    }\n\n    .wine-detail-label {\n      font-weight: 600;\n      display: inline;\n       color: #000000;\n    }\n\n    .wine-detail-value {\n      font-weight: 400;\n      display: inline;\n    }\n\n    .wine-description {\n      font-size: 8pt;\n      line-height: 1.3;\n      margin-top:1mm;\n     \n      color: #333333;\n      max-height: 20mm;\n      overflow: hidden;\n      text-overflow: ellipsis;\n      display: -webkit-box;\n      -webkit-line-clamp: 3;\n      -webkit-box-orient: vertical;\n    }\n\n    .wine-alcohol {\n      font-size: 6pt;\n      font-weight: 600;\n      color: #999999;\n      margin-top:1mm;\n    }\n    \n       .litry {\n      font-size: 6pt;\n      color: #999999;\n          font-weight: 400;\n    }\n    \n    .icon_wine {\n  background-image: url(http://witrynarium.pl/images/icons/wine.svg);\n  width: 24px;\n  height: 24px;\n  display: inline-block;\n      color: #999999;\n     \n}\n        .icon_glass {\n  background-image: url(http://witrynarium.pl/images/icons/glass.svg);\n  width: 24px;\n  height: 24px;\n  display: inline-block;\n      color: #999999;\n}\n    \n    .col{\n    width: 100%;    \n    height: 100%;\n    display: flex;\n        flex:1;\n    flex-direction: column;\n    align-content: center;\n    align-items: center;\n    justify-content: flex-end;\n      padding-left:4mm;\n      padding-right:4mm;\n      padding-top:8mm;\n      padding-bottom:8mm;\n      background-size:contain;\n      background-repeat: no-repeat;\n      \n    }\n    \n   \n    .logonorth{\n    background-image: url('https://witrynarium.pl/images/branding/logo.png');\n      background-size:contain;\n      background-repeat: no-repeat;\n      width:100px;\n      height:50px;\n    }\n \n    .footer{\n     width: 100%;\n    height: 10%;\n    text-align: center;\n    display: flex;\n    flex-direction: column;\n    align-content: center;\n    align-items: center;\n      justify-content: flex-start;\n    }\n    \n     .middle{\n     width: 100%;\n    height: 85%;\n    text-align: center;\n    display: flex;\n    flex-direction: column;\n    align-content: center;\n    align-items: center;\n       justify-content: center;\n    }\n    \n     .header{\n     width: 100%;\n    height: 5%;\n    text-align: center;\n    display: flex;\n    flex-direction: column;\n    align-content: center;\n    align-items: center;\n    }\n    \n    \n\n    /* Wymuszenie nowej strony dla kolejnych grup */\n    @media print {\n      .products-page {\n        page-break-after: always;\n      }\n    }\n  </style>\n</head>\n<body>\n\n  <!-- OKŁADKA -->\n  <div class=\"cover-page\" style=\"\">\n<div class=\"col\">\n  <div class=\"header\"></div>\n  <div class=\"middle\"><h1></h1></div>\n  <div class=\"footer\">\n  <div class=\"logonorth\"></div>\n  <span class=\"www\" style=\"color:#ffffff;\">www.northcoast.pl</span>\n    </div>\n  </div>\n  \n    <div class=\"col\">\n      <div class=\"header\"></div>\n   <div class=\"middle\"><h1></h1></div>\n  <div class=\"footer\">      <h1 style=\"color:#ffffff;\">{{collection.dynamicFieldsByName.Tytul}}</h1>    </div>\n  </div>\n  </div>\n  \n\n  <!-- STRONY Z PRODUKTAMI - Backend podzieli wina na grupy po 10 -->\n  {{#each winePages}}\n  <div class=\"products-page\">\n    {{#each this}}\n    <div class=\"wine-card\">\n      <!-- Lewa strona - Obraz -->\n      <div class=\"wine-image\">\n        <img src=\"https://witrynarium.pl{{this.image}}\" alt=\"{{this.name}}\">\n      </div>\n\n      <!-- Prawa strona - Treść -->\n      <div class=\"wine-content\">\n        <!-- Nagłówek - Nazwa i Ceny -->\n        <div class=\"wine-header-row\">\n          <h2 class=\"wine-title\">{{this.name}}</h2>\n          \n          <div class=\"wine-prices\">\n            <div class=\"price-badge\">\n              <span class=\"litry\">150ml</span><span class=\"icon_glass\"></span><span class=\"price-amount\" style=\"\">39zł</span>\n            </div>\n            <div class=\"price-badge\">\n              <span class=\"litry\">750ml</span><span class=\"icon_wine\"></span><span class=\"price-amount\">139zł</span>\n            </div>\n          </div>\n        </div>\n\n        <!-- Szczegóły -->\n        <div class=\"wine-details\">\n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Szczep:</span>\n            <span class=\"wine-detail-value\">{{this.szczepy}}</span>\n          </div>\n          \n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Region:</span>\n            <span class=\"wine-detail-value\">{{this.region}}</span>\n          </div>\n          \n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Typ:</span>\n            <span class=\"wine-detail-value\">{{this.type}}</span>\n          </div>\n\n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Kolor:</span>\n            <span class=\"wine-detail-value\">{{this.category}}</span>\n          </div>\n          \n          <p class=\"wine-description\">{{this.description}}</p>\n          \n          <div class=\"wine-alcohol\">Vol: {{this.alcohol}}</div>\n        </div>\n      </div>\n    </div>\n    {{/each}}\n  </div>\n  {{/each}}\n\n</body>\n</html>\n",
