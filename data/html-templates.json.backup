    "version": "1.0.0",
    "status": "draft",
    "metadata": {
      "pageFormat": {
        "width": 214,
        "height": 301,
        "unit": "mm"
      },
      "productsPerPage": 12,
      "gridLayout": {
        "columns": 2,
