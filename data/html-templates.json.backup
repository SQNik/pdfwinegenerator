  {
    "id": "cf5a977e-d95a-44fc-9a60-bbbdbbc2a180",
    "name": "Header10proc-3x30proc",
    "description": "",
    "category": "general",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n<meta charset=\"UTF-8\">\n\n<style>\n@page {\n    size: A4;\n    margin: 0mm;\n}\n\nbody {\n    margin: 0;\n    font-family: Arial, sans-serif;\n}\n\n/* Każda strona */\n.page {\n    width: 210mm;\n    height: 297mm;\n    display: grid;\n    grid-template-rows: 30mm 89mm 89mm 89mm;\n    break-after: page;\n    box-sizing: border-box;\n}\n\n/* Header */\n.header {\n    background: #eeeeee;\n    display: flex;\n    align-items: center;\n    padding: 0 15mm;\n    font-size: 18pt;\n    font-weight: bold;\n}\n\n/* Rząd z winem */\n.row {\n    display: flex;\n    padding: 10mm 15mm;\n    border-top: 1px solid #000;\n    box-sizing: border-box;\n    break-inside: avoid;\n}\n\n/* Kolumna obrazka */\n.image-col {\n    width: 30%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n}\n\n/* Obrazek */\n.product-image {\n    max-width: 100%;\n    max-height: 70mm;\n    object-fit: contain;\n}\n\n/* Kolumna treści */\n.content-col {\n    width: 70%;\n    padding-left: 10mm;\n}\n\nh4 {\n    margin: 0 0 5mm 0;\n    font-size: 14pt;\n}\n\np {\n    margin: 2mm 0;\n    font-size: 10pt;\n}\n  \n\n</style>\n\n</head>\n<body>\n\n{{#each collection.winesByCategory}}\n \n    <div class=\"page\">\n        <div class=\"header\">\n            {{category}}\n        </div>\n\n        {{#each wines}}\n        <div class=\"row\">\n\n            <div class=\"image-col\">\n                <img class=\"product-image\"\n                     src=\"https://witrynarium.pl{{this.image}}\">\n            </div>\n\n            <div class=\"content-col\">\n              <p><strong>Nr. Kat:</strong> {{this.catalogNumber}}</p>\n                <h4>{{this.name}}</h4>\n                <p><strong>Rodzaj:</strong> {{this.type}} / {{this.category}}</p>\n                <p><strong>Producent:</strong> {{this.producent}}</p>\n                <p><strong>Szczep:</strong> {{this.szczepy}}</p>\n                <p><strong>Region:</strong> {{this.region}}</p>\n                <p>{{this.description}}</p>\n            </div>\n\n        </div>\n        {{/each}}\n\n    </div>\n\n\n{{/each}}\n\n</body>\n</html>\n",
    "cssContent": "/* Dodatkowe style CSS */\n",
    "jsContent": "await page.pdf({\n  format: 'A4',\n  printBackground: true,\n  preferCSSPageSize: true\n});\n",
