  {
    "id": "fc662d25-3e22-4a86-876c-a97573872219",
    "name": "jedna-kolumna",
    "description": "",
    "category": "general",
    "htmlContent": "[component type=\"dynamicContainer\" id=\"dynamic_1761511284015\" templateId=\"edf50596-274b-4c1b-8830-b75345caa608\" wrapperTag=\"div\"]\n<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Karta Wina</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Poppins', sans-serif;\n            background: #f5f5f5;\n            padding: 0px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n           \n        }\n\n        .wine-card {\n            background: white;\n            border-radius: 0px;\n          border:1px solid #ddd;\n          \n            max-width: 900px;\n            width: 100%;\n            overflow: hidden;\n        }\n\n        .wine-card-inner {\n            display: grid;\n            grid-template-columns: 15% 85%;\n            gap: 8px;\n            padding: 8px;\n        }\n\n        /* Left side - Image (20%) */\n        .wine-image {\n            display: flex;\n            align-items: flex-start;\n            justify-content: center;\n        }\n\n        .wine-image img {\n            max-width: 100%;\n            height: auto;\n            \n            object-fit: contain;\n        }\n\n        /* Right side - Content (80%) */\n        .wine-content {\n            display: flex;\n            flex-direction: column;\n            gap: 0px;\n        }\n\n        /* Row 1 - Title and Prices */\n        .wine-header-row {\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-start;\n            gap: 24px;\n            \n        }\n\n        .wine-title {\n            font-size: 12pt;\n            font-weight: 700;\n            line-height: 1.3;\n            color: #1a1a1a;\n            text-transform: uppercase;\n            letter-spacing: -0.5px;\n            flex: 1;\n        }\n\n        .wine-prices {\n        display: flex\n;\n    gap: 4px;\n    flex-shrink: 0;\n    flex-direction: column;\n\n        }\n\n        .price-badge {\n    display: flex;\n    align-items: center;\n    gap: 0px;\n    background: white;\n    font-weight: 600;\n    white-space: nowrap;\n    justify-content: flex-end;\n        }\n\n        .price-volume {\n            font-size: 8pt;\n            color: #666;\n            display: flex;\n            align-items: center;\n            gap: 0px;\n          \n        }\n\n        .price-amount {\n            font-size: 10pt;\n            color: #1a1a1a;\n          border: 2px solid #1a1a1a;\n          border-radius: 24px;\n          padding: 4px 16px\n        }\n\n        /* Row 2 - Details (one under another) */\n        .wine-details {\n            display: flex;\n            flex-direction: column;\n            gap: 0px;\n        }\n\n        .wine-detail-item {\n            font-size: 8pt;\n            color: #2c2c2c;\n            line-height: 1.5;\n        }\n\n        .wine-detail-label {\n            font-weight: 600;\n            display: inline;\n        }\n\n        .wine-detail-value {\n            font-weight: 400;\n            display: inline;\n        }\n\n        .wine-description {\n            font-size: 8pt;\n            line-height: 1.4;\n            color: #2c2c2c;\n            text-align: justify;\n          margin-top:8px;\n          margin-bottom:8px;\n        }\n\n        .wine-alcohol {\n            font-size: 6pt;\n            font-weight: 600;\n            color: #2c2c2c;\n        }\n\n  \n    </style>\n</head>\n<body>\n\n    <div class=\"wine-card\">\n        <div class=\"wine-card-inner\">\n            <!-- Left side - Wine image (20%) -->\n            <div class=\"wine-image\">\n                <img src=\"wine-bottle.png\" alt=\"Bertani Amarone della Valpolicella\">\n            </div>\n\n            <!-- Right side - Wine info (80%) -->\n            <div class=\"wine-content\">\n                <!-- Row 1 - Title and Prices in one row -->\n                <div class=\"wine-header-row\">\n                    <h1 class=\"wine-title\">BERTANI AMARONE DELLA VALPOLICELLA CLASSICO DOCG</h1>\n                    \n                    <div class=\"wine-prices\">\n                        <div class=\"price-badge\">\n                          <span class=\"price-volume\">100ml <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\"><title>wine-glass-france-french-nation-holiday</title><g fill=\"#454444\"><path d=\"M18.43 9.1c-0.19-1.55-1.47-5.92-1.53-6.11a0.19 0.19 0 0 0-0.18-0.14h-9.12a0.19 0.19 0 0 0-0.18 0.14c-0.05 0.19-1.33 4.56-1.53 6.11-0.18 1.46 0.29 2.91 1.33 4.08 1.18 1.34 2.94 2.15 4.75 2.2v5.71h-3.61a0.19 0.19 0 0 0 0 0.38h7.6a0.19 0.19 0 0 0 0-0.38h-3.61v-5.71c1.8-0.05 3.57-0.86 4.75-2.2 1.04-1.17 1.51-2.62 1.33-4.08z m-10.69-5.87h8.84a116.49 116.49 0 0 1 0.93 3.42h-10.7c0.37-1.45 0.8-2.96 0.93-3.42z m9.07 9.7c-1.15 1.3-2.89 2.08-4.65 2.08s-3.5-0.78-4.65-2.08c-0.97-1.09-1.4-2.44-1.24-3.79 0.06-0.48 0.23-1.27 0.44-2.11h10.9c0.21 0.84 0.38 1.63 0.44 2.11 0.17 1.35-0.27 2.69-1.24 3.79z\" id=\"nccpEbene_1\"></path></g></svg><title>wine-glass-france-french-nation-holiday</title><g fill=\"#454444\"><path d=\"M48.496 23.939c-.503-4.086-3.873-15.592-4.017-16.08A.498.498 0 0 0 44 7.5H20a.5.5 0 0 0-.48.359c-.143.488-3.513 11.994-4.016 16.08-.473 3.84.771 7.656 3.503 10.746 3.111 3.518 7.75 5.646 12.493 5.788V55.5H22a.5.5 0 0 0 0 1h20a.5.5 0 0 0 0-1h-9.5V40.473c4.742-.143 9.382-2.271 12.493-5.789 2.733-3.089 3.976-6.905 3.503-10.745zM20.375 8.5h23.25a306.546 306.546 0 0 1 2.462 9H17.913c.967-3.804 2.114-7.8 2.462-9zm23.869 25.521C41.211 37.452 36.633 39.5 32 39.5s-9.21-2.048-12.244-5.479c-2.54-2.871-3.697-6.408-3.26-9.96.157-1.273.615-3.338 1.166-5.561h28.676c.551 2.223 1.009 4.288 1.166 5.561.437 3.552-.721 7.089-3.26 9.96z\" id=\"Ebene_1\"></path></g></svg></span>\n                            <span class=\"price-amount\">39zł</span>\n                        </div>\n                        <div class=\"price-badge\">\n                             <span class=\"price-volume\">750ml <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\"><title>alcohol-glass-bar-restaurant-drink-club</title><g fill=\"#454444\"><g id=\"nccpEbene_1\"><path d=\"M15.17 21.71c-0.13-0.07-0.54-0.3-0.54-0.43 0-0.23 0.44-0.49 0.65-0.59a0.19 0.19 0 0 0 0.11-0.19c-0.01-0.06-0.75-6.06-0.01-8.28 0.58-1.75-1.9-4.98-2.27-5.45v-2.21a0.19 0.19 0 0 0-0.19-0.19h-1.52a0.19 0.19 0 0 0-0.19 0.19v2.21c-0.37 0.47-2.85 3.69-2.27 5.45 0.74 2.21 0 8.22-0.01 8.28a0.19 0.19 0 0 0 0.11 0.19c0.26 0.12 0.65 0.38 0.65 0.59 0 0.13-0.41 0.36-0.54 0.43-0.21 0.11-0.34 0.19-0.31 0.36 0.04 0.16 0.22 0.16 0.28 0.16h6.08c0.06 0 0.23 0 0.28-0.16 0.04-0.17-0.09-0.24-0.31-0.36z m-5.51 0.14c0.22-0.15 0.41-0.33 0.41-0.57 0-0.42-0.5-0.74-0.75-0.87 0.11-0.93 0.69-6.18-0.02-8.31-0.55-1.66 2.22-5.11 2.25-5.14a0.19 0.19 0 0 0 0.04-0.12v-2.09h1.14v2.09a0.19 0.19 0 0 0 0.04 0.12c0.03 0.03 2.8 3.48 2.25 5.14-0.71 2.13-0.13 7.38-0.02 8.31-0.25 0.13-0.75 0.45-0.75 0.87 0 0.24 0.2 0.42 0.41 0.57l-5 0z\"></path><path d=\"M11.4 3.23h1.52a0.19 0.19 0 0 0 0.19-0.19v-0.76a0.19 0.19 0 0 0-0.19-0.19h-1.52a0.19 0.19 0 0 0-0.19 0.19v0.76a0.19 0.19 0 0 0 0.19 0.19z m0.19-0.76h1.14v0.38h-1.14v-0.38z\"></path><path d=\"M13.3 11.97h-2.28a0.19 0.19 0 0 0-0.19 0.19v6.08a0.19 0.19 0 0 0 0.19 0.19h2.28a0.19 0.19 0 0 0 0.19-0.19v-6.08a0.19 0.19 0 0 0-0.19-0.19z m-0.19 6.08h-1.9v-5.7h1.9v5.7z\"></path></g></g></svg></span>\n                            <span class=\"price-amount\">39zł</span>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Row 2 - Details (one under another) -->\n                <div class=\"wine-details\">\n                    <div class=\"wine-detail-item\">\n                        <span class=\"wine-detail-label\">Szczep:</span>\n                        <span class=\"wine-detail-value\">Corvina, Rondinella</span>\n                    </div>\n                    \n                    <div class=\"wine-detail-item\">\n                        <span class=\"wine-detail-label\">Region:</span>\n                        <span class=\"wine-detail-value\">Veneto</span>\n                    </div>\n                    \n                    <div class=\"wine-detail-item\">\n                        <span class=\"wine-detail-label\">Typ:</span>\n                        <span class=\"wine-detail-value\">wytrawne</span>\n                    </div>\n                    \n                    <p class=\"wine-description\">\n                        Intensywna czerwona barwa z cegłastymi przeblyskami. Bukiet niezwykle złożony z dominującymi akcentami dojrzałych ciemnych wiśni i śliwek oraz bogactwem aromatów orzechów, czarnej herbaty, lukrecji i przypraw korzennych.\n                    </p>\n                    \n                    <div class=\"wine-alcohol\">Vol: 9%</div>\n                </div>\n            </div>\n        </div>   \n \n   \n</body>\n</html>",
