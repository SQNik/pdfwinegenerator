  {
    "id": "872fdbf7-c4c9-47d4-9b76-f7b944342775",
    "name": "!Podział na kategorie w 2 kolumnach bck",
    "description": "",
    "category": "general",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Karta Wina</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    body {\n      font-family: 'Poppins', sans-serif;\n      background: #fff;\n      color: #1a1a1a;\n      font-size: 10pt;\n      line-height: 1.4;\n      margin: 0;\n      padding: 20px;\n    }\n\n    /* --- STRONA PODZIELONA NA DWIE RÓWNE KOLUMNY --- */\n    .wine-page {\n      columns: 2;                    /* dwie kolumny */\n      column-gap: 4mm;              /* odstęp między kolumnami */\n      column-fill: auto;             /* wypełnia najpierw lewą, potem prawą */\n      width: 100%;\n      height: 100%;                  /* mPDF/dompdf sam dostosuje wysokość strony */\n    }\n\n    /* Każda kategoria nie może się rozdzielać */\n    .category {\n                /* nie dziel kategorii między kolumny */\n      margin-bottom: 16px;\n    }\n\n    .category h1 {\n      background: #000;\n      color: #fff;\n      font-size: 14pt;\n      padding: 8px;\n      \n      text-align: center;\n      text-transform: uppercase;\n      line-height: 1.2;\n    }\n\n    .wine-card {\n      display: block;\n      /* margin-bottom: 12px;*/\n      margin-bottom: 2mm;\n      margin-top: 2mm;\n      border: 1px solid #ddd;\n      border-radius: 4px;\n      background: #fff;\n      padding: 0px;\n      break-inside: avoid;\n    }\n\n    .wine-card-inner {\n      display: grid;\n      grid-template-columns: 20% 80%;\n      gap: 0px;\n    }\n\n    /* Lewa kolumna - zdjęcie */\n    .wine-image {\n      display: flex;\n      justify-content: center;\n      align-items: flex-start;\n    }\n\n    .wine-image img {\n      max-width: 100%;\n      height: auto;\n      object-fit: contain;\n    }\n\n    /* Prawa kolumna - treść */\n    .wine-content {\n      display: flex;\n      flex-direction: column;\n      justify-content: space-between;\n    }\n\n    .wine-header-row {\n      display: flex;\n      justify-content: space-between;\n      align-items: flex-start;\n    }\n\n    .wine-title {\n      font-size: 11pt;\n      font-weight: 700;\n      text-transform: uppercase;\n      margin-right: 8px;\n    }\n\n    .wine-prices {\n      display: flex;\n      flex-direction: column;\n      align-items: flex-end;\n      gap: 2px;\n    }\n\n    .price-badge {\n      display: flex;\n      align-items: center;\n      justify-content: flex-end;\n      gap: 4px;\n    }\n\n    .price-volume {\n      font-size: 7pt;\n      color: #555;\n    }\n\n    .price-amount {\n      font-size: 9pt;\n      border: 1px solid #1a1a1a;\n      border-radius: 20px;\n      padding: 2px 8px;\n      font-weight: 600;\n    }\n\n    .wine-details {\n      margin-top: 0px;\n    }\n\n    .wine-detail-item {\n      font-size: 8pt;\n      color: #2c2c2c;\n      line-height: 1.4;\n    }\n\n    .wine-detail-label {\n      font-weight: 600;\n    }\n\n    .wine-description {\n      font-size: 8pt;\n      margin-top: 2mm;\n      margin-bottom: 2mm;\n      text-align: left;\ndisplay: -webkit-box;\n  -webkit-box-orient: vertical;\n  -webkit-line-clamp: 3;\n    overflow: hidden;\n    }\n\n    .wine-alcohol {\n      font-size: 7pt;\n      font-weight: 600;\n      color: #333;\n    }\n\n    /* --- Nowa strona po przepełnieniu obu kolumn --- */\n    .page-break {\n      break-after: page;\n    }\n\n  </style>\n</head>\n<body>\n\n  <div class=\"wine-page\">\n    {{#each collection.winesByCategory}}\n      <div class=\"category\">\n        <h1>Wina {{category}}</h1>\n        {{#each wines}}\n          <div class=\"wine-card\">\n            <div class=\"wine-card-inner\">\n              <!-- Zdjęcie -->\n              <div class=\"wine-image\">\n                <img src=\"https://witrynarium.pl{{wine.image}}\" alt=\"\">\n              </div>\n\n              <!-- Treść -->\n              <div class=\"wine-content\">\n                <div class=\"wine-header-row\">\n                  <h2 class=\"wine-title\">{{wine.name}}</h2>\n                  <div class=\"wine-prices\">\n                    <div class=\"price-badge\">\n                      <span class=\"price-volume\">100ml</span>\n                      <span class=\"price-amount\">39zł</span>\n                    </div>\n                    <div class=\"price-badge\">\n                      <span class=\"price-volume\">750ml</span>\n                      <span class=\"price-amount\">139zł</span>\n                    </div>\n                  </div>\n                </div>\n\n                <div class=\"wine-details\">\n                  <div class=\"wine-detail-item\"><span class=\"wine-detail-label\">Szczep:</span> {{wine.szczepy}}</div>\n                  <div class=\"wine-detail-item\"><span class=\"wine-detail-label\">Region:</span> {{wine.catalogNumber}} {{wine.region}}</div>\n                  <div class=\"wine-detail-item\"><span class=\"wine-detail-label\">Typ:</span> {{wine.type}}</div>\n                  <p class=\"wine-description\">{{wine.description}}</p>\n                  <div class=\"wine-alcohol\">Vol: {{wine.alcohol}}</div>\n                </div>\n              </div>\n            </div>\n          </div>\n        {{/each}}\n      </div>\n    {{/each}}\n  </div>\n\n</body>\n</html>\n",
    "cssContent": "/* Dodatkowe style CSS */\n.wine-card:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 8px 15px rgba(0,0,0,0.15);\n    transition: all 0.3s ease;\n}\n\n@media print {\n    body {\n        background: black;\n    }\n    \n    .wine-card {\n        box-shadow: none;\n        border: 1px solid #ddd;\n    }\n}",
    "jsContent": "",
    "thumbnailUrl": "",
