g/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\"><title>alcohol-glass-bar-restaurant-drink-club</title><g fill=\"#454444\"><g id=\"nccpEbene_1\"><path d=\"M15.17 21.71c-0.13-0.07-0.54-0.3-0.54-0.43 0-0.23 0.44-0.49 0.65-0.59a0.19 0.19 0 0 0 0.11-0.19c-0.01-0.06-0.75-6.06-0.01-8.28 0.58-1.75-1.9-4.98-2.27-5.45v-2.21a0.19 0.19 0 0 0-0.19-0.19h-1.52a0.19 0.19 0 0 0-0.19 0.19v2.21c-0.37 0.47-2.85 3.69-2.27 5.45 0.74 2.21 0 8.22-0.01 8.28a0.19 0.19 0 0 0 0.11 0.19c0.26 0.12 0.65 0.38 0.65 0.59 0 0.13-0.41 0.36-0.54 0.43-0.21 0.11-0.34 0.19-0.31 0.36 0.04 0.16 0.22 0.16 0.28 0.16h6.08c0.06 0 0.23 0 0.28-0.16 0.04-0.17-0.09-0.24-0.31-0.36z m-5.51 0.14c0.22-0.15 0.41-0.33 0.41-0.57 0-0.42-0.5-0.74-0.75-0.87 0.11-0.93 0.69-6.18-0.02-8.31-0.55-1.66 2.22-5.11 2.25-5.14a0.19 0.19 0 0 0 0.04-0.12v-2.09h1.14v2.09a0.19 0.19 0 0 0 0.04 0.12c0.03 0.03 2.8 3.48 2.25 5.14-0.71 2.13-0.13 7.38-0.02 8.31-0.25 0.13-0.75 0.45-0.75 0.87 0 0.24 0.2 0.42 0.41 0.57l-5 0z\"></path><path d=\"M11.4 3.23h1.52a0.19 0.19 0 0 0 0.19-0.19v-0.76a0.19 0.19 0 0 0-0.19-0.19h-1.52a0.19 0.19 0 0 0-0.19 0.19v0.76a0.19 0.19 0 0 0 0.19 0.19z m0.19-0.76h1.14v0.38h-1.14v-0.38z\"></path><path d=\"M13.3 11.97h-2.28a0.19 0.19 0 0 0-0.19 0.19v6.08a0.19 0.19 0 0 0 0.19 0.19h2.28a0.19 0.19 0 0 0 0.19-0.19v-6.08a0.19 0.19 0 0 0-0.19-0.19z m-0.19 6.08h-1.9v-5.7h1.9v5.7z\"></path></g></g></svg></span>\n                            <span class=\"price-amount\">39zł</span>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Row 2 - Details (one under another) -->\n                <div class=\"wine-details\">\n                    <div class=\"wine-detail-item\">\n                        <span class=\"wine-detail-label\">Szczep:</span>\n                        <span class=\"wine-detail-value\">Corvina, Rondinella</span>\n                    </div>\n                    \n                    <div class=\"wine-detail-item\">\n                        <span class=\"wine-detail-label\">Region:</span>\n                        <span class=\"wine-detail-value\">Veneto</span>\n                    </div>\n                    \n                    <div class=\"wine-detail-item\">\n                        <span class=\"wine-detail-label\">Typ:</span>\n                        <span class=\"wine-detail-value\">wytrawne</span>\n                    </div>\n                    \n                    <p class=\"wine-description\">\n                        Intensywna czerwona barwa z cegłastymi przeblyskami. Bukiet niezwykle złożony z dominującymi akcentami dojrzałych ciemnych wiśni i śliwek oraz bogactwem aromatów orzechów, czarnej herbaty, lukrecji i przypraw korzennych.\n                    </p>\n                    \n                    <div class=\"wine-alcohol\">Vol: 9%</div>\n                </div>\n            </div>\n        </div>   \n    </div>\n    \n   \n  </div>\n\n</body>\n</html>\n",
    "cssContent": "/* Dodatkowe style CSS */\n.wine-card:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 8px 15px rgba(0,0,0,0.15);\n    transition: all 0.3s ease;\n}\n\n@media print {\n    body {\n        background: white;\n    }\n    \n    .wine-card {\n        box-shadow: none;\n        border: 1px solid #ddd;\n    }\n}",
