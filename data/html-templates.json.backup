  {
    "id": "6db1d54e-d043-4826-9f75-979c2bb0f763",
    "name": "Rowne-wierszev2",
    "description": "",
    "category": "general",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Karta Win – podział na strony A4</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n<style>\n  * {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n  }\n\n  @page {\n    size: A4;\n    margin: 0;\n  }\n\n  body {\n    font-family: 'Poppins', sans-serif;\n    background: #f5f5f5;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 10mm 0;\n  }\n\n  /* --- STRONA A4 --- */\n  .a4-page {\n    width: 210mm;\n    height: 297mm;\n    background: white;\n    border: 1px solid #ccc;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n    margin-bottom: 10mm;\n    page-break-after: always;\n  }\n\n  .category h1 {\n    background: #000;\n    color: #fff;\n    font-size: 14pt;\n    padding: 12px;\n    text-align: center;\n  }\n\n  .wines-list {\n    display: flex;\n    flex-direction: column;\n    flex: 1;\n  }\n\n  .wine-card {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    border-bottom: 1px solid #ddd;\n    padding: 4mm 6mm;\n    overflow: hidden;\n  }\n\n  .wine-card-inner {\n    display: grid;\n    grid-template-columns: 20% 80%;\n    gap: 4mm;\n    height: 100%;\n  }\n\n  .wine-image {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n  }\n\n  .wine-image img {\n    width: 100%;\n    height: 100%;\n    object-fit: contain;\n  }\n\n  .wine-content {\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    overflow: hidden;\n  }\n\n  .wine-header-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    gap: 4mm;\n  }\n\n  .wine-title {\n    font-size: 11pt;\n    font-weight: 700;\n    line-height: 1.3;\n    color: #1a1a1a;\n    text-transform: uppercase;\n  }\n\n  .wine-prices {\n    display: flex;\n    flex-direction: column;\n    align-items: flex-end;\n    gap: 2mm;\n  }\n\n  .price-badge {\n    display: flex;\n    align-items: center;\n    gap: 2mm;\n  }\n\n  .price-volume {\n    font-size: 7pt;\n    color: #666;\n  }\n\n  .price-amount {\n    font-size: 9pt;\n    border: 1px solid #000;\n    border-radius: 24px;\n    padding: 2px 10px;\n  }\n\n  .wine-details {\n    font-size: 8pt;\n    line-height: 1.4;\n  }\n\n  .wine-description {\n    font-size: 8pt;\n    color: #2c2c2c;\n    text-align: justify;\n    display: -webkit-box;\n    -webkit-line-clamp: 3;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n\n  .wine-alcohol {\n    font-size: 7pt;\n    font-weight: 600;\n  }\n\n  @media print {\n    body {\n      background: white;\n      padding: 0;\n    }\n    .a4-page {\n      border: none;\n      margin: 0;\n      page-break-after: always;\n    }\n  }\n</style>\n</head>\n<body>\n\n<!-- Template dla strony A4 -->\n<div id=\"pages-container\"></div>\n\n<script>\n// Przykładowe dane (możesz podmienić na swoje)\nconst wines = [\n  { name: \"Chianti Classico\", szczepy: \"Sangiovese\", region: \"Toskania\", type: \"Wytrawne\", description: \"Intensywna czerwona barwa z ceglastymi przebłyskami. Bukiet niezwykle złożony z dominującymi akcentami dojrzałych ciemnych wiśni i śliwek oraz bogactwem aromatów orzechów, czarnej herbaty.\", alcohol: \"13.5%\", image: \"/uploads/wine1.jpg\" },\n  { name: \"Cabernet Sauvignon\", szczepy: \"Cabernet\", region: \"Francja\", type: \"Wytrawne\", description: \"Pełne ciało, delikatne taniny, nuta wanilii i czarnej porzeczki.\", alcohol: \"14%\", image: \"/uploads/wine2.jpg\" },\n  { name: \"Merlot Riserva\", szczepy: \"Merlot\", region: \"Włochy\", type: \"Półwytrawne\", description: \"Gładkie, zrównoważone, aromaty czerwonych owoców i czekolady.\", alcohol: \"13%\", image: \"/uploads/wine3.jpg\" },\n  { name: \"Tempranillo Rioja\", szczepy: \"Tempranillo\", region: \"Hiszpania\", type: \"Wytrawne\", description: \"Klasyczne Rioja z aromatami wiśni, skóry i dębu.\", alcohol: \"13.5%\", image: \"/uploads/wine4.jpg\" },\n  { name: \"Pinot Noir\", szczepy: \"Pinot Noir\", region: \"Burgundia\", type: \"Wytrawne\", description: \"Subtelne taniny, elegancki aromat czerwonych owoców i przypraw.\", alcohol: \"12.5%\", image: \"/uploads/wine5.jpg\" },\n  { name: \"Shiraz\", szczepy: \"Syrah\", region: \"Australia\", type: \"Wytrawne\", description: \"Gęste, pełne, z nutą pieprzu i czarnej porzeczki.\", alcohol: \"14.5%\", image: \"/uploads/wine6.jpg\" },\n  { name: \"Malbec\", szczepy: \"Malbec\", region: \"Argentyna\", type: \"Wytrawne\", description: \"Bogaty smak z nutą śliwek, malin i dębu.\", alcohol: \"13%\", image: \"/uploads/wine7.jpg\" },\n  { name: \"Primitivo di Manduria\", szczepy: \"Primitivo\", region: \"Apulia\", type: \"Półsłodkie\", description: \"Słodkie aromaty jagód, wanilii i przypraw.\", alcohol: \"15%\", image: \"/uploads/wine8.jpg\" },\n  { name: \"Carmenere\", szczepy: \"Carmenere\", region: \"Chile\", type: \"Wytrawne\", description: \"Zbalansowane wino o nutach czarnej porzeczki, papryki i kawy.\", alcohol: \"13%\", image: \"/uploads/wine9.jpg\" },\n  { name: \"Zinfandel\", szczepy: \"Zinfandel\", region: \"Kalifornia\", type: \"Półwytrawne\", description: \"Owocowe, z delikatną słodyczą i aromatem jeżyn.\", alcohol: \"14%\", image: \"/uploads/wine10.jpg\" },\n];\n\n// --- Parametry ---\nconst winesPerPage = 5;\nconst container = document.getElementById('pages-container');\n\n// --- Generowanie stron ---\nfor (let i = 0; i < wines.length; i += winesPerPage) {\n  const pageWines = wines.slice(i, i + winesPerPage);\n  const page = document.createElement('div');\n  page.classList.add('a4-page');\n  page.innerHTML = `\n    <div class=\"category\">\n      <h1>Wina czerwone</h1>\n    </div>\n    <div class=\"wines-list\">\n      ${pageWines.map(wine => `\n        <div class=\"wine-card\">\n          <div class=\"wine-card-inner\">\n            <div class=\"wine-image\">\n              <img src=\"${wine.image}\" alt=\"${wine.name}\">\n            </div>\n            <div class=\"wine-content\">\n              <div class=\"wine-header-row\">\n                <div class=\"wine-title\">${wine.name}</div>\n                <div class=\"wine-prices\">\n                  <div class=\"price-badge\"><span class=\"price-volume\">100ml</span><span class=\"price-amount\">39zł</span></div>\n                  <div class=\"price-badge\"><span class=\"price-volume\">750ml</span><span class=\"price-amount\">139zł</span></div>\n                </div>\n              </div>\n              <div class=\"wine-details\">\n                <div><strong>Szczep:</strong> ${wine.szczepy}</div>\n                <div><strong>Region:</strong> ${wine.region}</div>\n                <div><strong>Typ:</strong> ${wine.type}</div>\n                <p class=\"wine-description\">${wine.description}</p>\n                <div class=\"wine-alcohol\">Vol: ${wine.alcohol}</div>\n              </div>\n            </div>\n          </div>\n        </div>\n      `).join('')}\n    </div>\n  `;\n  container.appendChild(page);\n}\n</script>\n</body>\n</html>\n",
    "cssContent": "/* Dodatkowe style CSS */\n.wine-card:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 8px 15px rgba(0,0,0,0.15);\n    transition: all 0.3s ease;\n}\n\n@media print {\n    body {\n        background: white;\n    }\n    \n    .wine-card {\n        box-shadow: none;\n        border: 1px solid #ddd;\n    }\n}",
    "jsContent": "",
    "thumbnailUrl": "",
    "placeholders": [],
    "sampleData": {},
    "isPublic": false,
    "tags": [],
    "version": "1.0.0",
    "status": "draft",
    "metadata": {},
    "createdAt": "2025-10-25T15:05:49.725Z",
    "updatedAt": "2025-10-25T15:06:21.588Z"
  },
  {
    "id": "533d5fd2-dfdc-4cdf-ab8e-c1f9036cdad8",
    "name": "rowne wiersze z kategoria v3",
    "description": "",
    "category": "general",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Karta Win – kategorie jedna pod drugą</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n<style>\n  * {margin:0;padding:0;box-sizing:border-box;}\n  @page {size:A4;margin:0;}\n\n  body {\n    font-family: 'Poppins', sans-serif;\n    background: #f5f5f5;\n    padding: 10mm;\n  }\n\n  .a4-page {\n    width: 105mm;\n    min-height: 297mm;\n    background: white;\n    border: 1px solid #ccc;\n    margin: 0 auto 10mm auto;\n    padding: 10mm;\n    display: flex;\n    flex-direction: column;\n  }\n\n  .category {\n    margin-top: 10mm;\n  }\n\n  .category:first-of-type {\n    margin-top: 0;\n  }\n\n  .category h1 {\n    background: #000;\n    color: #fff;\n    font-size: 14pt;\n    padding: 8px;\n    text-align: center;\n    margin-bottom: 5mm;\n  }\n\n  .wines-list {\n    display: flex;\n    flex-direction: column;\n    gap: 3mm;\n  }\n\n  .wine-card {\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    border: 1px solid #ddd;\n    padding: 4mm 6mm;\n    overflow: hidden;\n  }\n\n  .wine-card-inner {\n    display: grid;\n    grid-template-columns: 20% 80%;\n    gap: 4mm;\n  }\n\n  .wine-image {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n  }\n\n  .wine-image img {\n    width: 100%;\n    height: 100%;\n    object-fit: contain;\n  }\n\n  .wine-content {\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    overflow: hidden;\n  }\n\n  .wine-header-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    gap: 4mm;\n  }\n\n  .wine-title {\n    font-size: 11pt;\n    font-weight: 700;\n    line-height: 1.3;\n    color: #1a1a1a;\n    text-transform: uppercase;\n  }\n\n  .wine-prices {\n    display: flex;\n    flex-direction: column;\n    align-items: flex-end;\n    gap: 2mm;\n  }\n\n  .price-badge {\n    display: flex;\n    align-items: center;\n    gap: 2mm;\n  }\n\n  .price-volume {\n    font-size: 7pt;\n    color: #666;\n  }\n\n  .price-amount {\n    font-size: 9pt;\n    border: 1px solid #000;\n    border-radius: 24px;\n    padding: 2px 10px;\n  }\n\n  .wine-details {\n    font-size: 8pt;\n    line-height: 1.4;\n  }\n\n  .wine-description {\n    font-size: 8pt;\n    color: #2c2c2c;\n    text-align: justify;\n    display: -webkit-box;\n    -webkit-line-clamp: 3;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n\n  .wine-alcohol {\n    font-size: 7pt;\n    font-weight: 600;\n  }\n\n  @media print {\n    body {\n      background: white;\n      padding: 0;\n    }\n\n    .a4-page {\n      border: none;\n      margin: 0;\n      padding: 10mm;\n      page-break-after: always;\n    }\n\n    .category {\n      \n    }\n\n    .wine-card {\n      break-inside: avoid;\n      page-break-inside: avoid;\n    }\n  }\n</style>\n</head>\n<body>\n<div class=\"a4-page\" id=\"content\"></div>\n\n<script>\n// Dane przykładowe\nconst wines = [\n  { name: \"Chianti Classico\", category: \"Wina czerwone\", szczepy: \"Sangiovese\", region: \"Toskania\", type: \"Wytrawne\", description: \"Intensywna czerwona barwa z ceglastymi przebłyskami. Bukiet niezwykle złożony z dominującymi akcentami dojrzałych ciemnych wiśni i śliwek oraz bogactwem aromatów orzechów, czarnej herbaty.\", alcohol: \"13.5%\", image: \"/uploads/wine1.jpg\" },\n  { name: \"Merlot Riserva\", category: \"Wina czerwone\", szczepy: \"Merlot\", region: \"Włochy\", type: \"Półwytrawne\", description: \"Gładkie, zrównoważone, aromaty czerwonych owoców i czekolady.\", alcohol: \"13%\", image: \"/uploads/wine3.jpg\" },\n  { name: \"Merlot Riserva\", category: \"Wina czerwone\", szczepy: \"Merlot\", region: \"Włochy\", type: \"Półwytrawne\", description: \"Gładkie, zrównoważone, aromaty czerwonych owoców i czekolady.\", alcohol: \"13%\", image: \"/uploads/wine3.jpg\" },\n  { name: \"Merlot Riserva\", category: \"Wina czerwone\", szczepy: \"Merlot\", region: \"Włochy\", type: \"Półwytrawne\", description: \"Gładkie, zrównoważone, aromaty czerwonych owoców i czekolady.\", alcohol: \"13%\", image: \"/uploads/wine3.jpg\" },\n  { name: \"Chardonnay\", category: \"Wina białe\", szczepy: \"Chardonnay\", region: \"Burgundia\", type: \"Wytrawne\", description: \"Aromatyczne wino o nutach jabłka, masła i wanilii.\", alcohol: \"12.5%\", image: \"/uploads/wine4.jpg\" },\n  { name: \"Riesling\", category: \"Wina białe\", szczepy: \"Riesling\", region: \"Niemcy\", type: \"Półwytrawne\", description: \"Świeże i cytrusowe z lekką słodyczą.\", alcohol: \"11%\", image: \"/uploads/wine5.jpg\" },\n  { name: \"Prosecco\", category: \"Wina musujące\", szczepy: \"Glera\", region: \"Wenecja Euganejska\", type: \"Wytrawne\", description: \"Delikatne bąbelki, lekko owocowe, przyjemne w ustach.\", alcohol: \"11%\", image: \"/uploads/wine6.jpg\" },\n  { name: \"Lambrusco\", category: \"Wina musujące\", szczepy: \"Lambrusco\", region: \"Emilia-Romania\", type: \"Półsłodkie\", description: \"Lekkie, musujące, przyjemnie owocowe.\", alcohol: \"10.5%\", image: \"/uploads/wine7.jpg\" },\n];\n\n// Grupowanie wg kategorii\nconst grouped = wines.reduce((acc, wine) => {\n  if (!acc[wine.category]) acc[wine.category] = [];\n  acc[wine.category].push(wine);\n  return acc;\n}, {});\n\n// Renderowanie kategorii jedna pod drugą\nconst container = document.getElementById('content');\nfor (const [category, wineList] of Object.entries(grouped)) {\n  const section = document.createElement('div');\n  section.classList.add('category');\n  section.innerHTML = `\n    <h1>${category}</h1>\n    <div class=\"wines-list\">\n      ${wineList.map(wine => `\n        <div class=\"wine-card\">\n          <div class=\"wine-card-inner\">\n            <div class=\"wine-image\"><img src=\"${wine.image}\" alt=\"${wine.name}\"></div>\n            <div class=\"wine-content\">\n              <div class=\"wine-header-row\">\n                <div class=\"wine-title\">${wine.name}</div>\n                <div class=\"wine-prices\">\n                  <div class=\"price-badge\"><span class=\"price-volume\">100ml</span><span class=\"price-amount\">39zł</span></div>\n                  <div class=\"price-badge\"><span class=\"price-volume\">750ml</span><span class=\"price-amount\">139zł</span></div>\n                </div>\n              </div>\n              <div class=\"wine-details\">\n                <div><strong>Szczep:</strong> ${wine.szczepy}</div>\n                <div><strong>Region:</strong> ${wine.region}</div>\n                <div><strong>Typ:</strong> ${wine.type}</div>\n                <p class=\"wine-description\">${wine.description}</p>\n                <div class=\"wine-alcohol\">Vol: ${wine.alcohol}</div>\n              </div>\n            </div>\n          </div>\n        </div>\n      `).join('')}\n    </div>\n  `;\n  container.appendChild(section);\n}\n</script>\n</body>\n</html>\n",
    "cssContent": "/* Dodatkowe style CSS */\n",
