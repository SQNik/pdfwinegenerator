  {
    "id": "83d6c543-14f6-482a-9462-d6ed1d33de61",
    "name": "Oferta z okladka",
    "description": "",
    "category": "general",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n<meta charset=\"UTF-8\" />\n\n<style>\n@page { size: A4; margin: 0; }\n\nhtml, body {\n  margin: 0;\n  padding: 0;\n  font-family: Arial, sans-serif;\n}\n\n/* ✅ 1 strona A4 - FLEX */\n.page {\n  width: 210mm;\n  height: 297mm;\n  display: flex;\n  flex-direction: column;\n  page-break-after: always;\n  break-after: page;\n  box-sizing: border-box;\n}\n\n/* Header - stała wysokość */\n.header {\n  background: #eeeeee;\n  height: 30mm;\n  flex-shrink: 0;\n  display: flex;\n  align-items: center;\n  padding: 0 15mm;\n  font-size: 18pt;\n  font-weight: 700;\n  box-sizing: border-box;\n}\n\n/* ✅ Wiersz z winem */\n.wine-row {\n  flex: 1;\n  display: grid;\n  grid-template-columns: 40mm 1fr; /* obrazek + treść */\n  gap: 8mm;\n  padding: 8mm 15mm;\n  border-top: 0.3mm solid #000;\n  box-sizing: border-box;\n  overflow: hidden;\n}\n\n/* Pudełko na obraz — stały rozmiar */\n.wine-imgbox{\n  width: 40mm;\n  height: 73mm;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n/* Obraz ma się zmieścić w pudełku w całości */\n.wine-imgbox img{\n  max-width: 100%;\n  max-height: 100%;\n  width: auto;\n  height: auto;\n  object-fit: contain;\n  display: block;\n}\n\n/* Teksty */\n.wine-title {\n  margin: 0 0 2mm 0;\n  font-size: 13pt;\n}\n\n.wine-meta {\n  margin: 0 0 1.5mm 0;\n  font-size: 10pt;\n}\n\n.wine-desc {\n  margin: 2mm 0 0 0;\n  font-size: 9.5pt;\n  line-height: 1.25;\n}\n\n/* ✅ Kontener \"Oferta z dnia\" na okładce */\n.cover-date {\n  flex-shrink: 0;\n  padding: 8mm 15mm;\n  border-top: 0.3mm solid #000;\n  box-sizing: border-box;\n}\n.cover-date .label{\n  font-size: 12pt;\n  font-weight: 700;\n  margin: 0;\n}\n.cover-date .value{\n  font-size: 12pt;\n  margin: 2mm 0 0 0;\n}\n</style>\n</head>\n\n<body>\n\n<!-- =========================\n     OKŁADKA (pierwsza strona)\n     ========================= -->\n\n<div class=\"page\">\n  <div class=\"header\">Wina: Oferta</div>\n\n  <div class=\"cover-date\">\n    <p class=\"label\">Oferta z dnia</p>\n    <!-- Podmień na swoje pole z datą, jeśli masz w danych (np. {{collection.offerDate}}) -->\n    <p class=\"value\">{{collection.offerDate}}</p>\n  </div>\n\n  <!-- 2 produkty na okładce: bierzemy pierwsze dwa z pierwszej kategorii/strony -->\n  {{#with (lookup collection.winesByCategory 0) as |firstCat|}}\n    {{#with (lookup firstCat.pages 0) as |firstPage|}}\n\n      {{#with (lookup firstPage 0) as |p|}}\n        <div class=\"wine-row\">\n          <div class=\"wine-imgbox\">\n            <img src=\"https://witrynarium.pl{{p.image}}\" alt=\"\">\n          </div>\n          <div>\n            <p class=\"wine-meta\"><strong>Nr kat:</strong> {{p.catalogNumber}}</p>\n            <h3 class=\"wine-title\">{{p.name}}</h3>\n            <p class=\"wine-meta\"><strong>Rodzaj wina i pojemność: </strong> {{p.category}} | {{p.type}} | {{p.poj}}</p>\n            <p class=\"wine-meta\"><strong>Producent:</strong> {{p.region}}</p>\n            <p class=\"wine-meta\"><strong>Szczep:</strong> {{p.szczepy}}</p>\n            <p class=\"wine-meta\"><strong>Region:</strong> {{p.region}}</p>\n            <p class=\"wine-meta\"><strong>Alk:</strong> {{p.alcohol}}</p>\n            <p class=\"wine-desc\">{{p.description}}</p>\n            <p class=\"wine-meta\"><strong>Cena:</strong> {{p.price1}}</p>\n          </div>\n        </div>\n      {{/with}}\n\n      {{#with (lookup firstPage 1) as |p|}}\n        <div class=\"wine-row\">\n          <div class=\"wine-imgbox\">\n            <img src=\"https://witrynarium.pl{{p.image}}\" alt=\"\">\n          </div>\n          <div>\n            <p class=\"wine-meta\"><strong>Nr kat:</strong> {{p.catalogNumber}}</p>\n            <h3 class=\"wine-title\">{{p.name}}</h3>\n            <p class=\"wine-meta\"><strong>Rodzaj wina i pojemność: </strong> {{p.category}} | {{p.type}} | {{p.poj}}</p>\n            <p class=\"wine-meta\"><strong>Producent:</strong> {{p.region}}</p>\n            <p class=\"wine-meta\"><strong>Szczep:</strong> {{p.szczepy}}</p>\n            <p class=\"wine-meta\"><strong>Region:</strong> {{p.region}}</p>\n            <p class=\"wine-meta\"><strong>Alk:</strong> {{p.alcohol}}</p>\n            <p class=\"wine-desc\">{{p.description}}</p>\n            <p class=\"wine-meta\"><strong>Cena:</strong> {{p.price1}}</p>\n          </div>\n        </div>\n      {{/with}}\n\n    {{/with}}\n  {{/with}}\n</div>\n\n\n<!-- =========================\n     STRONY KATEGORII (jak było)\n     ========================= -->\n\n{{#each collection.winesByCategory}}\n  {{#each pages}}\n    <div class=\"page\">\n      <div class=\"header\">Wina: {{category}}</div>\n\n      {{#each this}}\n        <div class=\"wine-row\">\n          <div class=\"wine-imgbox\">\n            <img src=\"https://witrynarium.pl{{this.image}}\" alt=\"\">\n          </div>\n          <div>\n            <p class=\"wine-meta\"><strong>Nr kat:</strong> {{this.catalogNumber}}</p>\n            <h3 class=\"wine-title\">{{this.name}}</h3>\n            <p class=\"wine-meta\"><strong>Rodzaj wina i pojemność: </strong> {{this.category}} | {{this.type}} | {{this.poj}}</p>\n            <p class=\"wine-meta\"><strong>Producent:</strong> {{this.region}}</p>\n            <p class=\"wine-meta\"><strong>Szczep:</strong> {{this.szczepy}}</p>\n            <p class=\"wine-meta\"><strong>Region:</strong> {{this.region}}</p>\n            <p class=\"wine-meta\"><strong>Alk:</strong> {{this.alcohol}}</p>\n            <p class=\"wine-desc\">{{this.description}}</p>\n            <p class=\"wine-meta\"><strong>Cena:</strong> {{this.price1}}</p>\n          </div>\n        </div>\n      {{/each}}\n\n    </div>\n  {{/each}}\n{{/each}}\n\n</body>\n</html>\n",
    "cssContent": "/* Dodatkowe style CSS */\n.wine-card:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 8px 15px rgba(0,0,0,0.15);\n    transition: all 0.3s ease;\n}\n\n@media print {\n    body {\n        background: white;\n    }\n    \n    .wine-card {\n        box-shadow: none;\n        border: 1px solid #ddd;\n    }\n}",
