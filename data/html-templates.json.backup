  {
    "id": "d8111491-a947-4234-bf95-06a09560e96e",
    "name": "3 produkty i header",
    "description": "",
    "category": "general",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n<meta charset=\"UTF-8\" />\n\n<style>\n@page { size: A4; margin: 0; }\n\nhtml, body {\n  margin: 0;\n  padding: 0;\n  font-family: Arial, sans-serif;\n}\n\n/* ✅ 1 strona A4 - FLEX zamiast grid-template-rows */\n.page {\n  width: 210mm;\n  height: 297mm;\n  display: flex;\n  flex-direction: column;\n  page-break-after: always;\n  break-after: page;\n  box-sizing: border-box;\n}\n\n/* Header - stała wysokość */\n.header {\n  background: #eeeeee;\n  height: 30mm;\n  flex-shrink: 0;\n  display: flex;\n  align-items: center;\n  padding: 0 15mm;\n  font-size: 18pt;\n  font-weight: 700;\n  box-sizing: border-box;\n}\n\n/* ✅ Wiersz z winem - każdy zajmuje 1/3 pozostałej wysokości */\n.wine-row {\n  flex: 1;\n  display: grid;\n  grid-template-columns: 40mm 1fr; /* obrazek + treść */\n  gap: 8mm;\n  padding: 8mm 15mm;\n  border-top: 0.3mm solid #000;\n  box-sizing: border-box;\n  overflow: hidden;       /* ✅ zabezpiecza przed “wypychem” na kolejną stronę */\n}\n\n/* Pudełko na obraz — stały rozmiar, żeby zawsze było w całości */\n.wine-imgbox{\n  width: 40mm;           /* tyle co kolumna obrazka */\n  height: 73mm;          /* dopasowane do layoutu (możemy skorygować) */\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n/* Obraz ma się zmieścić w pudełku w całości */\n.wine-imgbox img{\n  max-width: 100%;\n  max-height: 100%;\n  width: auto;\n  height: auto;\n  object-fit: contain;\n  display: block;\n}\n\n\n/* Teksty */\n.wine-title {\n  margin: 0 0 2mm 0;\n  font-size: 13pt;\n}\n\n.wine-meta {\n  margin: 0 0 1.5mm 0;\n  font-size: 10pt;\n}\n\n.wine-desc {\n  margin: 2mm 0 0 0;\n  font-size: 9.5pt;\n  line-height: 1.25;\n}\n</style>\n</head>\n\n<body>\n\n{{#each collection.winesByCategory}}\n  {{#each pages}}\n    <div class=\"page\">\n      <div class=\"header\">Wina: {{category}}</div>\n\n      {{#each this}}\n        <div class=\"wine-row\">\n          <div class=\"wine-imgbox\">\n    <img src=\"https://witrynarium.pl{{this.image}}\" alt=\"\">\n  </div>\n          <div>\n            <p class=\"wine-meta\"><strong>Nr kat:</strong> {{this.catalogNumber}}</p>\n            <h3 class=\"wine-title\">{{this.name}}</h3>\n            <p class=\"wine-meta\"><strong>Rodzaj wina i pojemność: </strong> {{this.category}} | {{this.type}} | {{this.poj}}</p>\n            <p class=\"wine-meta\"><strong>Producent:</strong> {{this.region}}</p>\n            <p class=\"wine-meta\"><strong>Szczep:</strong> {{this.szczepy}}</p>\n            <p class=\"wine-meta\"><strong>Region:</strong> {{this.region}}</p>\n            <p class=\"wine-meta\"><strong>Alk:</strong> {{this.alcohol}}</p>\n            <p class=\"wine-desc\">{{this.description}}</p>\n            <p class=\"wine-meta\"><strong>Cena:</strong> {{this.price1}}</p>\n          </div>\n        </div>\n      {{/each}}\n\n    </div>\n  {{/each}}\n{{/each}}\n\n</body>\n</html>\n",
    "cssContent": "/* Dodatkowe style CSS */\n",
