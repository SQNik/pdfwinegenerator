{
  "name": "wine-management-system",
  "version": "2.0.0",
  "description": "🔥 Revolutionary wine management system with dynamic field management, custom PDF formats, and business identifier system. Zero-code field configuration for end users.",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npm run check-fields && tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "check-fields": "node check-fields-sync.js",
    "fix-fields": "node auto-fix-fields-sync.js",
    "fix-and-check": "npm run fix-fields && npm run check-fields",
    "pm2:dev": "pm2 start ecosystem.config.json",
    "pm2:prod": "pm2 start ecosystem.config.json --env production",
    "pm2:stop": "pm2 stop wine-management-system",
    "pm2:restart": "pm2 restart wine-management-system",
    "pm2:reload": "pm2 reload wine-management-system",
    "pm2:delete": "pm2 delete wine-management-system",
    "pm2:logs": "pm2 logs wine-management-system",
    "pm2:monit": "pm2 monit",
    "production": "npm run build && npm run pm2:prod",
    "pre-import": "npm run check-fields",
    "post-import": "npm run check-fields",
    "validate-data": "npm run check-fields",
    "sync-fields": "npm run fix-and-check"
  },
  "keywords": [
    "wine",
    "management",
    "dynamic-fields",
    "zero-code",
    "typescript",
    "express",
    "rest-api",
    "pdf-generation",
    "custom-formats",
    "business-identifier",
    "real-time-sync",
    "field-validation",
    "collection-management",
    "template-editor"
  ],
  "author": "Wine Management System",
  "license": "MIT",
  "dependencies": {
    "@types/puppeteer": "^7.0.4",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "express-slow-down": "^3.0.0",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "node-fetch": "^2.7.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^24.25.0",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.4",
    "@types/node": "^20.5.0",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "jest": "^29.6.2",
    "prettier": "^3.0.2",
    "rimraf": "^5.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
