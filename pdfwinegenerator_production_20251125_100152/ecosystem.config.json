{
  "apps": [
    {
      "name": "wine-management-system",
      "script": "./dist/server.js",
      "cwd": "./",
      "instances": "max",
      "exec_mode": "cluster",
      "env": {
        "NODE_ENV": "development",
        "PORT": 3001,
        "LOG_LEVEL": "debug"
      },
      "env_production": {
        "NODE_ENV": "production",
        "PORT": 3001,
        "LOG_LEVEL": "info",
        "MAX_FILE_SIZE": "50mb",
        "RATE_LIMIT_WINDOW_MS": "900000",
        "RATE_LIMIT_MAX_REQUESTS": "1000",
        "CORS_ORIGIN": "http://localhost:3001",
        "CORS_CREDENTIALS": "true",
        "ENABLE_COMPRESSION": "true",
        "ENABLE_ETAG": "true",
        "ENABLE_STATIC_CACHE": "true",
        "STATIC_CACHE_MAX_AGE": "86400",
        "MONITORING_ENABLED": "true"
      },
      "watch": false,
      "ignore_watch": [
        "node_modules",
        "logs",
        "data",
        "public/pdf-output",
        "uploads"
      ],
      "max_memory_restart": "500M",
      "min_uptime": "10s",
      "max_restarts": 5,
      "restart_delay": 4000,
      "autorestart": true,
      "kill_timeout": 5000,
      "listen_timeout": 8000,
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "error_file": "./logs/pm2-error.log",
      "out_file": "./logs/pm2-out.log",
      "log_file": "./logs/pm2-combined.log",
      "pid_file": "./pids/wine-management.pid",
      "merge_logs": true,
      "log_type": "json",
      "time": true,
      "source_map_support": false,
      "instance_var": "INSTANCE_ID",
      "combine_logs": true,
      "vizion": false,
      "post_update": ["npm install", "npm run build"],
      "watch_options": {
        "followSymlinks": false,
        "usePolling": false
      },
      "node_args": [
        "--max-old-space-size=512"
      ],
      "args": [],
      "interpreterArgs": [],
      "automation": false,
      "pmx": true,
      "log_format": "combined",
      "append_env_to_name": false,
      "force": true,
      "disable_logs": false
    }
  ],
  "deploy": {
    "production": {
      "user": "node",
      "host": "your-server.com",
      "ref": "origin/main",
      "repo": "git@github.com:username/wine-management-system.git",
      "path": "/var/www/wine-management-system",
      "post-deploy": "npm install && npm run build && pm2 reload ecosystem.config.json --env production"
    }
  }
}