  {
    "id": "2a33410e-6621-4af1-a21c-25be2d7aada4",
    "name": "Karta wkładka",
    "description": "",
    "category": "general",
    "htmlContent": "<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"pagination\" content=\"firstPage:4,nextPages:5\">\n  <title>Karta Wina - Nagłówek + 4/5 produktów</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    body {\n      font-family: 'Poppins', sans-serif;\n      background: #fff;\n      color: device-cmyk(0%, 0%, 0%, 100%);\n      font-size: 9pt;\n      line-height: 1.3;\n      margin: 0;\n      padding: 0;\n    }\n\n    /* === PIERWSZA STRONA - NAGŁÓWEK + 4 PRODUKTY === */\n    .first-page {\n      width: 109mm;\n      height: 301mm;\n      page-break-after: always;\n      display: flex;\n      flex-direction: column;\n    background:{{collection.dynamicFieldsByName.kolor_okladki}};\n      background-image: url('{{collection.dynamicFieldsByName.tlo_okladki}}');\n      background-size:contain;\n    }\n\n    /* Nagłówek - 20% wysokości */\n    .page-header {\n      height: 20%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background-size: cover;\n      background-position: center;\n      padding: 4mm;\n      border-bottom: 1px dashed #ddd;\n    }\n\n    .header-title {\n      font-size: 24pt;\n      font-weight: 700;\n      color: device-cmyk(0%, 0%, 0%, 100%);\n      text-align: center;\n      \n    }\n\n    /* Produkty na pierwszej stronie - 80% wysokości / 4 = 20% każdy */\n    .first-page-products {\n      height: 80%;\n      display: flex;\n      flex-direction: column;\n    }\n\n    .first-page-products .wine-card {\n      height: 25%; /* 80% / 4 = 20% każdy produkt */\n      flex-shrink: 0;\n    }\n\n    /* === KOLEJNE STRONY - 5 PRODUKTÓW === */\n    .products-page {\n      width: 109mm;\n      height: 301mm;\n      page-break-after: always;\n      display: flex;\n      flex-direction: column;\n        background:{{collection.dynamicFieldsByName.kolor_listy}};\n      background-image: url(\"{{collection.dynamicFieldsByName.tlo_listy}}\");\n      background-size: contain;\n      background-position: top;\n    }\n\n    .products-page .wine-card {\n      height: 20%; /* 100% / 5 = 20% każdy produkt */\n      flex-shrink: 0;\n    }\n\n    /* === KARTA PRODUKTU === */\n    .wine-card {\n      display: grid;\n      grid-template-columns: 15% 85%; /* 15% obraz, 85% treść */\n      gap: 1mm;\n      padding: 6mm;\n      border: 0px solid #ddd;\n      overflow: hidden;\n    }\n\n    /* Lewa strona - Obraz */\n    .wine-image {\n      display: flex;\n      align-items: flex-start;\n      justify-content: flex-start;\n      padding-right: 0mm;\n    }\n\n    .wine-image img {\n      max-width: 100%;\n      height: auto;\n      object-fit: cover;\n    }\n\n    /* Prawa strona - Treść */\n    .wine-content {\n      display: flex;\n      flex-direction: column;\n      gap: 2mm;\n    }\n\n    /* Wiersz nagłówka - Nazwa i Ceny */\n    .wine-header-row {\n      display: flex;\n      justify-content: space-between;\n      align-items: flex-start;\n      gap: 4mm;\n    }\n\n    .wine-title {\n      font-size: 12pt;\n      font-weight: 700;\n      line-height: 1.2;\n      color: device-cmyk(0%, 0%, 0%, 100%);\n      text-transform: uppercase;\n      letter-spacing: -0.5px;\n      flex: 1;\n    }\n\n    .wine-prices {\n      display: flex;\n      gap: 2mm;\n      flex-shrink: 0;\n      flex-direction: column;\n    }\n\n    .price-badge {\n      display: flex;\n      align-items: center;\n      gap: 0mm;\n      font-weight: 600;\n      white-space: nowrap;\n      justify-content: flex-end;\n    }\n\n    .price-amount {\n      text-align: right;\n      font-size: 10pt;\n       font-weight: bold;\n      color: device-cmyk(0%, 0%, 0%, 100%);\n      border: 1px solid #1a1a1a;\n      border-radius: 1mm;\n      padding: 2px 12px;\n      flex:1;\n    }\n\n    /* Szczegóły wina */\n    .wine-details {\n      display: flex;\n      flex-direction: column;\n      gap: 0.5mm;\n    }\n\n    .wine-detail-item {\n      display: block;\n      font-size: 8pt;\n      color: device-cmyk(0%, 0%, 0%, 80%);\n      line-height: 1.3;\n    }\n\n    .wine-detail-label {\n      font-weight: 600;\n      display: inline;\n       color: device-cmyk(0%, 0%, 0%, 100%);\n    }\n\n    .wine-detail-value {\n      font-weight: 400;\n      display: inline;\n    }\n\n    .wine-description {\n      font-size: 8pt;\n      line-height: 1.3;\n      margin-top:1mm;\n     \n      color: device-cmyk(0%, 0%, 0%, 80%);\n      max-height: 20mm;\n      overflow: hidden;\n      text-overflow: ellipsis;\n      display: -webkit-box;\n      -webkit-line-clamp: 3;\n      -webkit-box-orient: vertical;\n    }\n\n    .wine-alcohol {\n      font-size: 6pt;\n      font-weight: 600;\n      color: device-cmyk(0%, 0%, 0%, 60%);\n      margin-top:1mm;\n    }\n    \n       .litry {\n      font-size: 6pt;\n      color: device-cmyk(0%, 0%, 0%, 60%);\n          font-weight: 400;\n    }\n    \n    .icon_wine {\n  background-image: url(http://witrynarium.pl/images/icons/wine.svg);\n  width: 24px;\n  height: 24px;\n  display: inline-block;\n      color: device-cmyk(0%, 0%, 0%, 60%);\n     \n}\n        .icon_glass {\n  background-image: url(http://witrynarium.pl/images/icons/glass.svg);\n  width: 24px;\n  height: 24px;\n  display: inline-block;\n      color: device-cmyk(0%, 0%, 0%, 60%);\n}\n\n    /* Wymuszenie nowej strony */\n    @media print {\n      .first-page,\n      .products-page {\n        page-break-after: always;\n      }\n    }\n  </style>\n</head>\n<body>\n\n  <!-- PIERWSZA STRONA - NAGŁÓWEK + 4 PRODUKTY -->\n  <div class=\"first-page\">\n    <!-- Nagłówek z tłem z dynamicznego pola -->\n    <div class=\"page-header\" style=\"background-image: url('{{collection.dynamicFieldsByName.zwykly_tekst}}');\">\n      <h1 class=\"header-title\">{{collection.dynamicFieldsByName.Tytul}}</h1>\n    </div>\n\n    <!-- Pierwsze 4 produkty -->\n    <div class=\"first-page-products\">\n      {{#each firstPageWines}}\n      <div class=\"wine-card\">\n      <!-- Lewa strona - Obraz -->\n      <div class=\"wine-image\">\n        <img src=\"https://witrynarium.pl{{this.image}}\" alt=\"{{this.name}}\">\n      </div>\n\n      <!-- Prawa strona - Treść -->\n      <div class=\"wine-content\">\n        <!-- Nagłówek - Nazwa i Ceny -->\n        <div class=\"wine-header-row\">\n          <h2 class=\"wine-title\">{{this.name}}</h2>\n          \n          <div class=\"wine-prices\">\n            <div class=\"price-badge\">\n              <span class=\"litry\">150ml</span><span class=\"icon_glass\"></span><span class=\"price-amount\" style=\"\">39zł</span>\n            </div>\n            <div class=\"price-badge\">\n              <span class=\"litry\">750ml</span><span class=\"icon_wine\"></span><span class=\"price-amount\">139zł</span>\n            </div>\n          </div>\n        </div>\n\n        <!-- Szczegóły -->\n        <div class=\"wine-details\">\n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Szczep:</span>\n            <span class=\"wine-detail-value\">{{this.szczepy}}</span>\n          </div>\n          \n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Region:</span>\n            <span class=\"wine-detail-value\">{{this.region}}</span>\n          </div>\n          \n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Typ:</span>\n            <span class=\"wine-detail-value\">{{this.type}}</span>\n          </div>\n\n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Kolor:</span>\n            <span class=\"wine-detail-value\">{{this.category}}</span>\n          </div>\n          \n          <p class=\"wine-description\">{{this.description}}</p>\n          \n          <div class=\"wine-alcohol\">Vol: {{this.alcohol}}</div>\n        </div>\n      </div>\n    </div>\n      {{/each}}\n    </div>\n  </div>\n\n  <!-- KOLEJNE STRONY - PO 5 PRODUKTÓW -->\n  {{#each restPages}}\n  <div class=\"products-page\">\n    {{#each this}}\n   <div class=\"wine-card\">\n      <!-- Lewa strona - Obraz -->\n      <div class=\"wine-image\">\n        <img src=\"https://witrynarium.pl{{this.image}}\" alt=\"{{this.name}}\">\n      </div>\n\n      <!-- Prawa strona - Treść -->\n      <div class=\"wine-content\">\n        <!-- Nagłówek - Nazwa i Ceny -->\n        <div class=\"wine-header-row\">\n          <h2 class=\"wine-title\">{{this.name}}</h2>\n          \n          <div class=\"wine-prices\">\n            <div class=\"price-badge\">\n              <span class=\"litry\">150ml</span><span class=\"icon_glass\"></span><span class=\"price-amount\" style=\"\">39zł</span>\n            </div>\n            <div class=\"price-badge\">\n              <span class=\"litry\">750ml</span><span class=\"icon_wine\"></span><span class=\"price-amount\">139zł</span>\n            </div>\n          </div>\n        </div>\n\n        <!-- Szczegóły -->\n        <div class=\"wine-details\">\n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Szczep:</span>\n            <span class=\"wine-detail-value\">{{this.szczepy}}</span>\n          </div>\n          \n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Region:</span>\n            <span class=\"wine-detail-value\">{{this.region}}</span>\n          </div>\n          \n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Typ:</span>\n            <span class=\"wine-detail-value\">{{this.type}}</span>\n          </div>\n\n          <div class=\"wine-detail-item\">\n            <span class=\"wine-detail-label\">Kolor:</span>\n            <span class=\"wine-detail-value\">{{this.category}}</span>\n          </div>\n          \n          <p class=\"wine-description\">{{this.description}}</p>\n          \n          <div class=\"wine-alcohol\">Vol: {{this.alcohol}}</div>\n        </div>\n      </div>\n    </div>\n    {{/each}}\n  </div>\n  {{/each}}\n\n</body>\n</html>\n",
    "cssContent": "/* Dodatkowe style CSS */\n.wine-card:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 8px 15px rgba(0,0,0,0.15);\n    transition: all 0.3s ease;\n}\n\n@media print {\n    body {\n        background: white;\n    }\n    \n    .wine-card {\n        box-shadow: none;\n        border: 1px solid #ddd;\n    }\n}",
